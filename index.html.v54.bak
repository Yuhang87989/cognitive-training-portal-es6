        if (!e.target.closest('.user-menu-wrapper')) { document.getElementById('user-dropdown').classList.remove('show'); }
    });
});

function initLoginPage() {
    const data = loadData();
    renderUserList();
    if (data.users.length === 0) { showCreateUserModal(); }
}

