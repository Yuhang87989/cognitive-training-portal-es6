<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
<meta name="theme-color" content="#3377FF"/>
<title>认知训练</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--white:#FFFFFF;--bg-page:#F5F6FA;--text-dark:#333;--text-gray:#666;--text-light:#999;--border-gray:#F2F4F7;--gradient-orange:linear-gradient(135deg,#FF9A63,#E87A4E);--gradient-blue:linear-gradient(135deg,#3377FF,#4A80F5);--gradient-purple:linear-gradient(135deg,#667eea,#764ba2);--gradient-green:linear-gradient(135deg,#43E97B,#38F9D7);--card-shadow:0 4px 16px rgba(0,0,0,0.05);--blue:#3377FF;--orange:#E87A4E}
body{font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Helvetica Neue',Arial,sans-serif;background:var(--bg-page);min-height:100vh;color:var(--text-dark);padding-bottom:80px;max-width:480px;margin:0 auto}
.page{display:none;min-height:100vh;background:var(--bg-page);padding-bottom:80px}
.page.active{display:block}
.login-page{display:flex;min-height:100vh;background:linear-gradient(180deg,#E8F4FF,#f0f4ff);flex-direction:column;align-items:center;padding:20px}
.login-header-bg{width:100%;height:160px;background:linear-gradient(135deg,#3377FF,#00D2FF);border-radius:0 0 40px 40px;position:absolute;top:0;left:50%;transform:translateX(-50%);width:480px;max-width:100vw}
.login-content{width:100%;max-width:360px;padding:0 20px;margin-top:120px;position:relative;z-index:10}
.login-logo-area{text-align:center;margin-bottom:24px}
.login-avatar{width:80px;height:80px;background:white;border-radius:50%;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:40px;box-shadow:0 4px 20px rgba(0,0,0,0.15)}
.login-title{font-size:24px;font-weight:bold;color:#1a1a2e;margin-bottom:4px}
.login-subtitle{font-size:13px;color:#666}
.login-card{background:white;border-radius:20px;padding:24px;box-shadow:0 4px 20px rgba(51,119,255,0.15);margin-bottom:16px}
.user-select-wrapper{position:relative;margin-bottom:16px}
.user-select-btn{width:100%;padding:14px 16px;background:#f5f7ff;border:2px solid var(--blue);border-radius:12px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;font-size:15px}
.user-select-arrow{transition:transform 0.3s;font-size:12px}
.user-select-dropdown{position:absolute;top:100%;left:0;right:0;background:white;border:2px solid var(--blue);border-radius:12px;margin-top:4px;display:none;z-index:100;max-height:200px;overflow-y:auto}
.user-select-dropdown.show{display:block}
.user-select-item{padding:12px 16px;display:flex;align-items:center;gap:10px;cursor:pointer;border-bottom:1px solid #f0f0f0}
.user-select-item:hover{background:#f5f7ff}
.user-select-item .item-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px}
.user-select-item .item-name{font-size:14px;font-weight:600}
.user-select-item .item-grade{font-size:11px;color:var(--text-light)}
.input-group{margin-bottom:16px}
.input-label{font-size:13px;color:var(--text-gray);margin-bottom:8px}
.input-field{width:100%;padding:12px 14px;border:2px solid var(--border-gray);border-radius:12px;font-size:15px;outline:none;box-sizing:border-box}
.input-field:focus{border-color:var(--blue)}
.login-btn{width:100%;padding:16px;border:none;border-radius:14px;font-size:15px;font-weight:600;cursor:pointer;transition:all 0.2s}
.login-btn-primary{background:linear-gradient(135deg,#3377FF,#FF9A63);color:white;box-shadow:0 4px 15px rgba(51,119,255,0.3)}
.login-btn-secondary{background:#f0f0f0;color:var(--text-dark);margin-top:10px}
.login-btn-outline{background:white;border:2px solid var(--blue);color:var(--blue);margin-top:10px}
.create-modal{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:none;align-items:center;justify-content:center;z-index:1000;padding:20px}
.create-modal.show{display:flex}
.create-modal-content{background:white;border-radius:20px;padding:24px;width:100%;max-width:360px;max-height:85vh;overflow-y:auto}
.create-modal-title{font-size:18px;font-weight:bold;text-align:center;margin-bottom:20px}
.home-header{background:linear-gradient(135deg,#E8F4FF,#D4ECFF);padding:16px 16px 20px;border-radius:0 0 24px 24px}
.header-top{display:flex;justify-content:space-between;align-items:center}
.app-logo{width:44px;height:44px;background:linear-gradient(135deg,#3377FF,#FF9A63);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px}
.difficulty-tag{background:rgba(255,149,0,0.1);padding:6px 12px;border-radius:18px;font-size:12px;color:var(--orange);cursor:pointer}
.user-menu-wrapper{position:relative}
.user-avatar-circle{width:42px;height:42px;background:linear-gradient(135deg,#FFD4B8,#FFB6C1);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:bold;color:#fff;cursor:pointer}
.user-dropdown{position:absolute;top:100%;right:0;background:white;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.15);width:200px;display:none;z-index:100;margin-top:8px}
.user-dropdown.show{display:block}
.user-dropdown-header{padding:16px;border-bottom:1px solid #f0f0f0}
.user-dropdown-name{font-size:15px;font-weight:bold;margin-bottom:4px}
.user-dropdown-info{font-size:12px;color:var(--text-gray)}
.user-dropdown-item{padding:14px 16px;display:flex;align-items:center;gap:10px;cursor:pointer;border-bottom:1px solid #f5f5f5}
.user-dropdown-item:hover{background:#f5f7ff}
.user-dropdown-item.danger{color:#ff6b6b}
.module-section{padding:16px 12px 0}
.module-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px}
.module-btn{display:flex;flex-direction:column;align-items:center;padding:14px 6px 10px;border-radius:16px;border:none;cursor:pointer;transition:transform 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.08);position:relative;min-height:90px}
.module-btn:active{transform:scale(0.96)}
.module-icon{font-size:26px;margin-bottom:6px}
.module-name{font-size:12px;font-weight:bold;color:white;margin-bottom:2px;text-align:center}
.module-desc{font-size:9px;color:rgba(255,255,255,0.9);text-align:center}
.module-tag{position:absolute;top:-4px;right:-4px;background:#FF6B6B;color:white;font-size:8px;padding:2px 5px;border-radius:8px;font-weight:bold}
.gradient-blue{background:linear-gradient(135deg,#3377FF,#4A80F5)}
.gradient-orange{background:linear-gradient(135deg,#FF9A63,#E87A4E)}
.gradient-green{background:linear-gradient(135deg,#43E97B,#38F9D7)}
.gradient-purple{background:linear-gradient(135deg,#667eea,#764ba2)}
.gradient-pink{background:linear-gradient(135deg,#FFB6C1,#FF9A63)}
.gradient-cyan{background:linear-gradient(135deg,#4facfe,#00f2fe)}
.gradient-yellow{background:linear-gradient(135deg,#f6d365,#fda085)}
.gradient-red{background:linear-gradient(135deg,#ff6b6b,#ff4757)}
.today-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:12px}
.stat-item{background:white;border-radius:12px;padding:10px 6px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.05)}
.stat-value{font-size:18px;font-weight:bold;color:var(--blue)}
.stat-label{font-size:10px;color:var(--text-light);margin-top:2px}
.bottom-nav{display:fixed;bottom:0;left:50%;transform:translateX(-50%);width:480px;max-width:100vw;background:white;border-top:1px solid #f0f0f0;display:flex;padding:8px 0;z-index:50}#page-login .bottom-nav,#page-login~.bottom-nav{display:none!important}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:6px;cursor:pointer;color:var(--text-light);transition:all 0.2s}
.nav-item.active{color:var(--blue)}
.nav-icon{font-size:22px;margin-bottom:2px}
.nav-label{font-size:10px}
.fullscreen-page{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--bg-page);z-index:200;display:none;flex-direction:column;overflow:hidden}
.fullscreen-page.active{display:flex}
.fp-header{display:flex;align-items:center;padding:12px 16px;background:white;border-bottom:1px solid #f0f0f0}
.fp-back{font-size:20px;cursor:pointer;padding:8px}
.fp-title{flex:1;font-size:16px;font-weight:bold;text-align:center}
.fp-content{flex:1;overflow-y:auto;padding:12px;background:var(--bg-page)}
.fp-nav{display:flex;background:white;border-top:1px solid #f0f0f0;padding:8px 0}
.fp-nav-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:6px;cursor:pointer;color:var(--text-light);font-size:10px}
.fp-nav-item.active{color:var(--blue)}
.fp-nav-icon{font-size:20px;margin-bottom:2px}
.card{background:white;border-radius:16px;padding:16px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.05)}
.chat-container{flex:1;display:flex;flex-direction:column;background:#f8f9fa}
.chat-messages{flex:1;overflow-y:auto;padding:12px}
.chat-msg{display:flex;gap:10px;margin-bottom:12px}
.chat-msg.user{flex-direction:row-reverse}
.chat-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.chat-msg.user .chat-avatar{background:linear-gradient(135deg,#FF9A63,#E87A4E)}
.chat-bubble{max-width:75%;padding:10px 14px;border-radius:16px;background:white;font-size:14px;line-height:1.5}
.chat-msg.user .chat-bubble{background:var(--gradient-blue);color:white}
.chat-input-area{padding:12px;background:white;border-top:1px solid #eee;display:flex;gap:8px;align-items:center}
.chat-input{flex:1;padding:10px 14px;border:1px solid #ddd;border-radius:20px;font-size:14px;outline:none}
.chat-send{padding:10px 18px;background:var(--gradient-blue);border:none;border-radius:20px;color:white;font-size:14px;cursor:pointer}
.template-btns{display:flex;gap:6px;padding:8px 12px;overflow-x:auto;background:#f8f9fa}
.template-btn{padding:6px 12px;background:white;border:1px solid #ddd;border-radius:16px;font-size:12px;white-space:nowrap}
.teacher-list{display:flex;gap:12px;padding:12px;overflow-x:auto}
.teacher-item{display:flex;flex-direction:column;align-items:center;padding:10px 8px;border-radius:12px;cursor:pointer;background:white;border:2px solid transparent;flex-shrink:0;min-width:80px}
.teacher-item.active{border-color:#667eea;background:rgba(102,126,234,0.1)}
.teacher-avatar{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px}
.teacher-name{font-size:12px;font-weight:600;margin-top:6px}
.teacher-subject{font-size:10px;color:var(--text-light)}
.game-board{display:grid;gap:10px;margin:0 auto;max-width:300px}
.game-board.size-3{grid-template-columns:repeat(3,1fr)}
.game-board.size-4{grid-template-columns:repeat(4,1fr)}
.game-cell{aspect-ratio:1;background:var(--border-gray);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;cursor:pointer}
.game-cell:active{transform:scale(0.95)}
.games-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;padding:12px}
.game-card{background:white;border-radius:16px;padding:16px;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.08);text-align:center}
.game-icon-area{width:56px;height:56px;border-radius:16px;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:28px}
.game-name{font-size:13px;font-weight:600;margin-bottom:2px}
.game-desc{font-size:10px;color:var(--text-light)}
.gradient-blue-solid{background:linear-gradient(135deg,#3377FF,#4A80F5);color:white}
.gradient-orange-blue{background:linear-gradient(135deg,#FF9A63,#E87A4E);color:white}
.gradient-purple-pink{background:linear-gradient(135deg,#667eea,#764ba2);color:white}
.gradient-green{background:linear-gradient(135deg,#43E97B,#38F9D7);color:white}
.gradient-cyan{background:linear-gradient(135deg,#4facfe,#00f2fe);color:white}
.gradient-yellow{background:linear-gradient(135deg,#f6d365,#fda085);color:white}
.gradient-pink{background:linear-gradient(135deg,#FFB6C1,#FF9A63);color:white}
.game-btn{padding:10px 20px;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer}
.btn-blue{background:var(--blue);color:white}
.btn-orange{background:var(--orange);color:white}
.btn-green{background:#43E97B;color:white}
.method-card{background:white;border-radius:12px;padding:16px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.05);cursor:pointer}
.method-title{font-size:14px;font-weight:600;margin-bottom:8px}
.method-content{font-size:13px;color:var(--text-gray);line-height:1.6}
.topic-card{background:white;border-radius:16px;overflow:hidden;margin-bottom:12px;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.05)}
.topic-header{padding:16px;color:white}
.topic-title{font-size:14px;font-weight:600}
.topic-subtitle{font-size:12px;opacity:0.9;margin-top:4px}
.topic-footer{padding:12px 16px;display:flex;justify-content:space-between;align-items:center}
.topic-difficulty{font-size:12px;color:var(--text-gray)}
.grade-tab{display:flex;gap:8px;padding:12px;background:white;border-radius:12px;margin-bottom:12px}
.grade-tab-btn{flex:1;padding:10px;background:#f5f5f5;border:none;border-radius:8px;font-size:13px;cursor:pointer}
.grade-tab-btn.active{background:var(--blue);color:white}
.subject-tab{display:flex;gap:6px;padding:8px 12px;overflow-x:auto}
.subject-tab-btn{padding:8px 14px;background:white;border:1px solid #ddd;border-radius:20px;font-size:12px;white-space:nowrap;cursor:pointer}
.subject-tab-btn.active{background:var(--blue);color:white;border-color:var(--blue)}
.radar-container{position:relative;margin:10px auto}
.heatmap-grid{display:grid;gap:4px;margin-top:12px}
.heatmap-cell{aspect-ratio:1;border-radius:4px;background:var(--border-gray)}
.plan-calendar{background:white;border-radius:12px;padding:12px;margin-top:12px}
.calendar-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.calendar-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:50%;font-size:12px;cursor:pointer}
.calendar-day.checked{background:var(--blue);color:white}
.calendar-day.today{background:rgba(255,149,0,0.2);color:var(--orange);font-weight:bold}
.calendar-day.disabled{color:#ccc;cursor:not-allowed}
.plan-task{display:flex;align-items:center;gap:12px;padding:12px;background:var(--border-gray);border-radius:12px;margin-bottom:8px;cursor:pointer}
.plan-task.completed{opacity:0.6}
.task-checkbox{width:24px;height:24px;border-radius:50%;border:2px solid var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.task-checkbox.checked{background:var(--blue);color:white}
.task-text{flex:1;font-size:14px}
.task-time{font-size:11px;color:var(--text-light)}
.audio-controls{display:flex;align-items:center;gap:12px}
.audio-progress{flex:1;height:4px;background:#e0e0e0;border-radius:2px;cursor:pointer}
.audio-progress-bar{height:100%;background:var(--blue);border-radius:2px;transition:width 0.1s}
.audio-time{font-size:11px;color:var(--text-gray)}
.audio-btn{width:44px;height:44px;border-radius:50%;background:var(--gradient-blue);border:none;color:white;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.podcast-item{display:flex;gap:12px;padding:12px;background:white;margin-bottom:8px;border-radius:12px;cursor:pointer}
.podcast-thumb{width:60px;height:60px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0}
.podcast-info{flex:1}
.podcast-title{font-size:14px;font-weight:600;margin-bottom:4px}
.podcast-meta{font-size:11px;color:var(--text-light)}
.video-item{display:flex;gap:12px;padding:12px;background:white;margin-bottom:8px;border-radius:12px;cursor:pointer}
.video-thumb{width:100px;height:70px;background:#f0f0f0;border-radius:8px;display:flex;align-items:center;justify-content:center;position:relative;flex-shrink:0}
.play-icon{position:absolute;font-size:24px;color:white;text-shadow:0 1px 3px rgba(0,0,0,0.5)}
.video-info{flex:1}
.video-title{font-size:14px;font-weight:600;margin-bottom:4px}
.video-meta{font-size:11px;color:var(--text-light)}
.video-player-modal{position:fixed;top:0;left:0;right:0;bottom:0;background:#000;z-index:1000;display:none;flex-direction:column}
.video-player-modal.show{display:flex}
.vp-header{display:flex;align-items:center;padding:12px 16px;background:rgba(0,0,0,0.8)}
.vp-back{color:white;font-size:20px;cursor:pointer;padding:8px}
.vp-title{flex:1;color:white;font-size:14px}
.vp-container{flex:1;display:flex;align-items:center;justify-content:center}
.vp-container video{width:100%;height:100%;object-fit:contain}
.vp-controls{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.8));padding:30px 16px 20px}
.vp-progress{width:100%;height:5px;background:rgba(255,255,255,0.3);border-radius:3px;cursor:pointer}
.vp-progress-bar{height:100%;background:white;border-radius:3px}
.vp-btn{background:none;border:none;color:white;font-size:24px;cursor:pointer;padding:10px}
.vp-time{color:white;font-size:13px}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:none;align-items:center;justify-content:center;z-index:1000;padding:20px}
.modal-overlay.show{display:flex}
.modal-content{background:white;border-radius:20px;padding:24px;width:100%;max-width:360px;max-height:80vh;overflow-y:auto}
.modal-title{font-size:18px;font-weight:bold;text-align:center;margin-bottom:20px}
.modal-close{width:100%;padding:14px;background:var(--gradient-blue);border:none;border-radius:12px;color:white;font-size:15px;font-weight:600;cursor:pointer;margin-top:12px}
.settings-panel{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);display:none;align-items:flex-start;justify-content:center;padding-top:60px;z-index:300}
.settings-panel.show{display:flex}
.settings-content{background:white;width:100%;max-width:400px;border-radius:0 0 20px 20px;padding:20px;max-height:70vh;overflow-y:auto}
.settings-balance{background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-radius:16px;padding:16px;margin-bottom:16px}
.settings-item{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid #f0f0f0}
.upload-zone{border:2px dashed #ccc;border-radius:12px;padding:30px 20px;text-align:center;cursor:pointer;margin:16px 0;background:#fafafa}
.upload-zone:hover{border-color:var(--blue);background:#f0f7ff}
.upload-icon{font-size:36px;margin-bottom:8px}
.upload-text{font-size:13px;color:var(--text-gray)}
.upload-hint{font-size:10px;color:var(--text-light);margin-top:4px}
.toast{position:fixed;bottom:100px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.8);color:white;padding:12px 24px;border-radius:20px;font-size:14px;z-index:9999;animation:fadeIn 0.3s}
@keyframes fadeIn{from{opacity:0;transform:translateX(-50%) translateY(20px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.loading-dots{display:inline-flex;gap:4px}
.loading-dots span{width:8px;height:8px;background:var(--blue);border-radius:50%;animation:dot 1.4s infinite}
.loading-dots span:nth-child(1){animation-delay:-0.32s}
.loading-dots span:nth-child(2){animation-delay:-0.16s}
@keyframes dot{0%,80%,100%{transform:scale(0)}50%{transform:scale(1)}}
.ai-loading{color:var(--blue);font-size:13px}
.wrong-note-card{background:#f5f7ff;border-radius:12px;padding:12px;margin-bottom:10px}
.wrong-note-question{font-size:14px;margin-bottom:6px}
.wrong-note-answer{font-size:12px;color:var(--blue)}
.camera-btn.recording{animation:pulse 1s infinite;background:#ff4757!important}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.6}}
.practice-card{background:white;border-radius:12px;padding:16px;margin-bottom:10px}
.practice-question{font-size:14px;margin-bottom:12px;line-height:1.6}
.practice-input{display:flex;gap:8px;margin-bottom:12px}
.practice-input input{flex:1;padding:10px;border:2px solid #ddd;border-radius:8px;font-size:14px}
.practice-input button{padding:10px 16px;background:var(--blue);color:white;border:none;border-radius:8px;font-size:14px}
.practice-result{padding:10px;border-radius:8px;margin-top:8px;font-size:14px}
.practice-result.correct{background:#e8f5e9;color:#2e7d32}
.practice-result.wrong{background:#ffebee;color:#c62828}
.practice-result .answer-highlight{font-weight:bold;color:var(--blue)}
.practice-result .explanation{font-size:13px;color:var(--text-gray);margin-top:8px}
.thinking-card{background:white;border-radius:12px;padding:16px;margin-bottom:10px}
.thinking-header{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.thinking-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px}
.thinking-title{font-size:14px;font-weight:600;flex:1}
.thinking-question{font-size:13px;color:var(--text-gray);line-height:1.5;margin-bottom:12px}
.thinking-options{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.thinking-option{padding:10px;background:#f5f5f5;border-radius:8px;font-size:13px;text-align:center;cursor:pointer;border:2px solid transparent}
.thinking-option.selected{border-color:var(--blue);background:rgba(51,119,255,0.1)}
.thinking-option.correct{border-color:#43E97B;background:rgba(67,233,123,0.1)}
.thinking-option.wrong{border-color:#FF6B6B;background:rgba(255,107,107,0.1)}
.camera-btn{width:100%;padding:14px;background:var(--gradient-blue);color:white;border:none;border-radius:12px;font-size:15px;font-weight:600;cursor:pointer;margin-bottom:12px}
.image-list{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px}
.image-item{aspect-ratio:1;background:#f0f0f0;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:24px;position:relative;overflow:hidden}
.image-item img{width:100%;height:100%;object-fit:cover}
.image-item .delete-btn{position:absolute;top:4px;right:4px;background:rgba(255,0,0,0.8);color:white;border:none;border-radius:50%;width:20px;height:20px;font-size:12px;cursor:pointer}
.stats-bar{display:flex;justify-content:space-around;padding:12px;background:white;border-radius:12px;margin-bottom:12px}
.stats-bar-item{text-align:center}
.stats-bar-value{font-size:20px;font-weight:bold;color:var(--blue)}
.stats-bar-label{font-size:10px;color:var(--text-light)}
</style>
</head>
<body>

<!-- 登录页 -->
<div id="page-login" class="page login-page active">
    <div class="login-header-bg"></div>
    <div class="login-content">
        <div class="login-logo-area">
            <div class="login-avatar">🧠</div>
            <div class="login-title">认知训练</div>
            <div class="login-subtitle">青少年注意力和记忆力训练</div>
        </div>
        <div class="login-card">
            <div class="user-select-wrapper">
                <div class="user-select-btn" onclick="toggleUserSelect()">
                    <span id="selected-user-display">👤 选择学习者</span>
                    <span class="user-select-arrow">▼</span>
                </div>
                <div class="user-select-dropdown" id="user-select-dropdown">
                    <div id="user-list-container"></div>
                </div>
            </div>
            <div id="login-form-section">
                <div class="input-group">
                    <label class="input-label">⚡ 难度级别</label>
                    <select class="input-field" id="login-difficulty">
                        <option value="1">Lv.1 入门</option>
                        <option value="2" selected>Lv.2 基础</option>
                        <option value="3">Lv.3 进阶</option>
                        <option value="4">Lv.4 挑战</option>
                        <option value="5">Lv.5 大师</option>
                    </select>
                </div>
                <button class="login-btn login-btn-primary" onclick="handleLogin()">🚀 开始训练</button>
            </div>
            <button class="login-btn login-btn-outline" onclick="showCreateUserModal()" style="margin-top:12px;">➕ 创建新账号</button>
            <button class="login-btn login-btn-secondary" onclick="confirmClearAllData()" style="margin-top:8px;font-size:12px;">🗑️ 清除所有数据</button>
        </div>
    </div>
</div>

<!-- 创建用户模态框 -->
<div class="create-modal" id="create-user-modal">
    <div class="create-modal-content">
        <div class="create-modal-title">✨ 创建新账号</div>
        <div class="input-group">
            <label class="input-label">👤 你的名字</label>
            <input type="text" class="input-field" id="create-name" maxlength="10" placeholder="请输入名字"/>
        </div>
        <div class="input-group">
            <label class="input-label">📚 年级</label>
            <select class="input-field" id="create-grade">
                <option value="5">五年级</option>
                <option value="6">六年级</option>
                <option value="7" selected>初一</option>
                <option value="8">初二</option>
                <option value="9">初三</option>
            </select>
        </div>
        <div class="input-group">
            <label class="input-label">⚡ 初始难度</label>
            <select class="input-field" id="create-difficulty">
                <option value="1" selected>Lv.1 入门</option>
                <option value="2">Lv.2 基础</option>
                <option value="3">Lv.3 进阶</option>
                <option value="4">Lv.4 挑战</option>
                <option value="5">Lv.5 大师</option>
            </select>
        </div>
        <button class="login-btn login-btn-primary" onclick="createNewUser()">✓ 创建账号</button>
        <button class="login-btn login-btn-secondary" onclick="closeCreateUserModal()">取消</button>
    </div>
</div>

<!-- 用户切换模态框 -->
<div class="modal-overlay" id="user-switch-modal">
    <div class="modal-content">
        <div class="modal-title">👥 切换用户</div>
        <div id="switch-user-list"></div>
        <button class="login-btn login-btn-secondary" onclick="closeUserSwitchModal()">关闭</button>
    </div>
</div>

<!-- 难度调整模态框 -->
<div class="modal-overlay" id="difficulty-modal">
    <div class="modal-content">
        <div class="modal-title">⚡ 调整难度</div>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:16px;">
            <button class="level-btn" data-level="1" onclick="setDifficulty(1)" style="padding:12px;border:2px solid #ddd;border-radius:8px;background:white;cursor:pointer;">Lv.1</button>
            <button class="level-btn" data-level="2" onclick="setDifficulty(2)" style="padding:12px;border:2px solid #ddd;border-radius:8px;background:white;cursor:pointer;">Lv.2</button>
            <button class="level-btn" data-level="3" onclick="setDifficulty(3)" style="padding:12px;border:2px solid #ddd;border-radius:8px;background:white;cursor:pointer;">Lv.3</button>
            <button class="level-btn" data-level="4" onclick="setDifficulty(4)" style="padding:12px;border:2px solid #ddd;border-radius:8px;background:white;cursor:pointer;">Lv.4</button>
            <button class="level-btn" data-level="5" onclick="setDifficulty(5)" style="padding:12px;border:2px solid #ddd;border-radius:8px;background:white;cursor:pointer;">Lv.5</button>
        </div>
        <button class="login-btn login-btn-secondary" onclick="closeDifficultyModal()">关闭</button>
    </div>
</div>

<!-- 首页 -->
<div id="page-home" class="page">
    <div class="home-header">
        <div class="header-top">
            <div class="app-logo">🧠</div>
            <div style="display:flex;align-items:center;gap:8px;">
                <div class="difficulty-tag" onclick="openDifficultyModal()">
                    <span id="difficulty-text">Lv.1</span>
                </div>
                <div class="user-menu-wrapper">
                    <div class="user-avatar-circle" id="header-avatar" onclick="toggleUserMenu()">同</div>
                    <div class="user-dropdown" id="user-dropdown">
                        <div class="user-dropdown-header">
                            <div class="user-dropdown-name" id="dropdown-name">同学</div>
                            <div class="user-dropdown-info" id="dropdown-info">初一 · Lv.1</div>
                        </div>
                        <div class="user-dropdown-item" onclick="showUserSwitchModal()"><span>👥</span><span>切换用户</span></div>
                        <div class="user-dropdown-item" onclick="openSettingsPanel()"><span>⚙️</span><span>设置</span></div>
                        <div class="user-dropdown-item danger" onclick="logoutAndReturn()"><span>🚪</span><span>退出登录</span></div>
                    </div>
                </div>
            </div>
        </div>
        <div style="margin-top:12px;">
            <span id="greeting-name">同学</span>，今天也要加油哦 💪
        </div>
        <div class="today-stats">
            <div class="stat-item">
                <div class="stat-value" id="today-questions">0</div>
                <div class="stat-label">提问</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="today-correct">0%</div>
                <div class="stat-label">正确率</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="today-minutes">0</div>
                <div class="stat-label">分钟</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="today-streak">0</div>
                <div class="stat-label">连续天数</div>
            </div>
        </div>
    </div>

    <div class="module-section">
        <div class="module-grid">
            <button class="module-btn gradient-blue" onclick="openFullscreenPage('avatar')">
                <div class="module-icon">🎓</div>
                <div class="module-name">AI数字分身</div>
                <div class="module-desc">5位AI老师</div>
            </button>
            <button class="module-btn gradient-orange" onclick="openFullscreenPage('practice')">
                <span class="module-tag" style="background:#667eea;">AI</span>
                <div class="module-icon">🎯</div>
                <div class="module-name">AI精准练</div>
                <div class="module-desc">薄弱点诊断</div>
            </button>
            <button class="module-btn gradient-green" onclick="openFullscreenPage('map')">
                <div class="module-icon">🧠</div>
                <div class="module-name">认知地图</div>
                <div class="module-desc">能力可视化</div>
            </button>
            <button class="module-btn gradient-purple" onclick="openFullscreenPage('plan')">
                <span class="module-tag" style="background:#43E97B;">NEW</span>
                <div class="module-icon">📅</div>
                <div class="module-name">学习计划</div>
                <div class="module-desc">Week1-5训练</div>
            </button>
            <button class="module-btn gradient-pink" onclick="openFullscreenPage('topics')">
                <div class="module-icon">📚</div>
                <div class="module-name">母题训练</div>
                <div class="module-desc">126道经典题</div>
            </button>
            <button class="module-btn gradient-cyan" onclick="openFullscreenPage('method')">
                <div class="module-icon">💡</div>
                <div class="module-name">学霸方法</div>
                <div class="module-desc">高效学习技巧</div>
            </button>
            <button class="module-btn gradient-yellow" onclick="openFullscreenPage('thinking')">
                <div class="module-icon">🧩</div>
                <div class="module-name">思维训练</div>
                <div class="module-desc">四维能力提升</div>
            </button>
            <button class="module-btn gradient-blue" onclick="openFullscreenPage('podcast')">
                <div class="module-icon">🎧</div>
                <div class="module-name">播客课堂</div>
                <div class="module-desc">音频学习</div>
            </button>
            <button class="module-btn gradient-orange" onclick="openFullscreenPage('video')">
                <div class="module-icon">📺</div>
                <div class="module-name">视频课堂</div>
                <div class="module-desc">视频学习</div>
            </button>
            <button class="module-btn gradient-green" onclick="openFullscreenPage('games')">
                <div class="module-icon">🎮</div>
                <div class="module-name">训练游戏</div>
                <div class="module-desc">8大认知游戏</div>
            </button>
            <button class="module-btn gradient-purple" onclick="openFullscreenPage('deepseek')">
                <div class="module-icon">🤖</div>
                <div class="module-name">DeepSeek</div>
                <div class="module-desc">AI智能助手</div>
            </button>
            <button class="module-btn gradient-red" onclick="openSettingsPanel()">
                <div class="module-icon">⚙️</div>
                <div class="module-name">设置</div>
                <div class="module-desc">账户与充值</div>
            </button>
        </div>
    </div>
</div>

<!-- 设置面板 -->
<div id="settings-panel" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:300;" onclick="closeSettingsPanel(event)">
    <div style="background:white;width:100%;max-width:400px;border-radius:0 0 20px 20px;padding:20px;" onclick="event.stopPropagation()">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
            <div style="font-size:18px;font-weight:bold;">⚙️ 设置</div>
            <div onclick="closeSettingsPanel()" style="cursor:pointer;font-size:20px;padding:8px;">✕</div>
        </div>
        <div style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-radius:16px;padding:16px;margin-bottom:16px;">
            <div style="font-size:15px;font-weight:600;margin-bottom:8px;">DeepSeek API</div>
            <div style="font-size:12px;opacity:0.9;margin-bottom:12px;">API Key已配置 · 所有AI功能可用</div>
            <button onclick="openDeepSeekRecharge()" style="width:100%;padding:12px;background:white;color:#667eea;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;">💰 充值余额</button>
        </div>
        <div style="font-size:14px;font-weight:600;margin-bottom:12px;">通用设置</div>
        <div class="settings-item">
            <span>清除所有数据</span>
            <button onclick="clearAllData()" style="background:#ff6b6b;color:white;border:none;padding:6px 12px;border-radius:6px;font-size:12px;cursor:pointer;">清除</button>
        </div>
    </div>
</div>

<!-- 全屏子页面 -->
<div class="fullscreen-page" id="fullscreen-container">
    <div class="fp-header">
        <div class="fp-back" onclick="closeFullscreenPage()">←</div>
        <div class="fp-title" id="fullscreen-title">页面标题</div>
        <div style="width:40px;"></div>
    </div>
    <div class="fp-content" id="fullscreen-content"></div>
    <div class="fp-nav">
        <div class="fp-nav-item" onclick="closeFullscreenPage()">
            <div class="fp-nav-icon">🏠</div><div>首页</div>
        </div>
        <div class="fp-nav-item" onclick="openFullscreenPage('games')">
            <div class="fp-nav-icon">🎮</div><div>训练</div>
        </div>
        <div class="fp-nav-item" onclick="openFullscreenPage('map')">
            <div class="fp-nav-icon">🧠</div><div>认知</div>
        </div>
        <div class="fp-nav-item" onclick="openFullscreenPage('deepseek')">
            <div class="fp-nav-icon">🤖</div><div>AI</div>
        </div>
    </div>
</div>

<!-- 视频播放器 -->
<div class="video-player-modal" id="video-player-modal">
    <div class="vp-header">
        <div class="vp-back" onclick="closeVideoPlayer()">←</div>
        <div class="vp-title" id="vp-title">视频播放</div>
        <div style="width:40px;"></div>
    </div>
    <div class="vp-container" id="vp-container">
        <video id="vp-video" playsinline></video>
    </div>
    <div class="vp-controls">
        <div class="vp-progress" onclick="seekVideo(event)">
            <div class="vp-progress-bar" id="vp-progress-bar"></div>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;">
            <button class="vp-btn" onclick="toggleVpPlay()" id="vp-play-btn">▶</button>
            <span class="vp-time" id="vp-time">0:00 / 0:00</span>
            <button class="vp-btn" onclick="toggleVolume()" id="vp-volume-btn">🔊</button>
        </div>
    </div>
</div>

<!-- 通用模态框 -->
<div class="modal-overlay" id="detail-modal">
    <div class="modal-content" id="detail-content" style="max-width:400px;"></div>
</div>


<!-- 隐藏的音频元素 -->
<audio id="hidden-audio" style="display:none;"></audio>

<!-- 增强版视频播放器 -->
<div id="enhanced-video-player" style="position:fixed;top:0;left:0;right:0;bottom:0;background:#000;z-index:2000;display:none;flex-direction:column;">
    <video id="evp-video" playsinline style="width:100%;height:100%;object-fit:contain;"></video>
    <!-- 控制面板 -->
    <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.8));padding:20px;">
        <div id="evp-title" style="color:white;font-size:16px;font-weight:bold;margin-bottom:12px;"></div>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
            <span id="evp-time" style="color:white;font-size:12px;min-width:80px;">0:00 / 0:00</span>
            <div id="evp-progress" style="flex:1;height:4px;background:rgba(255,255,255,0.3);border-radius:2px;cursor:pointer;" onclick="seekEnhancedVideo(event)">
                <div id="evp-progress-bar" style="height:100%;background:var(--blue);border-radius:2px;width:0%;"></div>
            </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:12px;">
                <button onclick="toggleEnhancedVideoPlay()" style="background:none;border:none;color:white;font-size:20px;cursor:pointer;" id="evp-play-btn">▶</button>
                <button onclick="seekEnhancedVideoBackward()" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;">⏪</button>
                <button onclick="seekEnhancedVideoForward()" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;">⏩</button>
            </div>
            <div style="display:flex;align-items:center;gap:12px;">
                <button id="evp-speed-btn" onclick="toggleEnhancedSpeedDropdown()" style="background:none;border:none;color:white;font-size:12px;cursor:pointer;">1x</button>
                <button id="evp-volume-btn" onclick="toggleEnhancedMute()" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;">🔊</button>
                <button onclick="togglePictureInPicture()" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;">📺</button>
                <button onclick="toggleEnhancedFullscreen()" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;">⛶</button>
                <button onclick="closeEnhancedVideoPlayer()" style="background:none;border:none;color:white;font-size:18px;cursor:pointer;">✕</button>
            </div>
        </div>
    </div>
    <div id="evp-big-play" onclick="toggleEnhancedVideoPlay()" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:80px;height:80px;background:rgba(255,255,255,0.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:36px;cursor:pointer;">▶</div>
</div>

<script>
// ====== 全局配置 ======
const DEEPSEEK_API_KEY = 'sk-8413f72a3f084fb08c84389555a76d37';
const DEEPSEEK_API_URL = 'https://api.deepseek.com/chat/completions';
const DEEPSEEK_MODEL = 'deepseek-chat'; // DeepSeek模型，新用户有免费额度
const STORAGE_KEY = 'cognitive_training_v49';
const OLD_KEYS = ['cognitive_training_v43', 'cognitive_training_v42', 'cognitive_training_v41', 'cognitive_training_v40', 'cognitive_training_v33', 'cognitive_training_v32'];
function migrateData() {
    for (const key of OLD_KEYS) {
        const old = localStorage.getItem(key);
        if (old && !localStorage.getItem(STORAGE_KEY)) {
            localStorage.setItem(STORAGE_KEY, old);
            console.log('数据已迁移:', key, '->', STORAGE_KEY);
        }
    }
}

// ====== 数据存储 ======
function loadData() {
    migrateData();
    try {
        const data = localStorage.getItem(STORAGE_KEY);
        if (data) return JSON.parse(data);
    } catch(e) {}
    return { users: [], currentUser: null };
}

function saveData(data) {
    try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch(e) {}
}

function getCurrentUserData() {
    const data = loadData();
    if (!data.currentUser) return null;
    return data.users.find(u => u.id === data.currentUser) || null;
}

function syncUserData(user) {
    const data = loadData();
    const idx = data.users.findIndex(u => u.id === user.id);
    if (idx >= 0) { data.users[idx] = user; saveData(data); }
}

const gradeNames = {5:'五年级',6:'六年级',7:'初一',8:'初二',9:'初三'};

// ====== 用户管理 ======
function toggleUserSelect() {
    document.getElementById('user-select-dropdown').classList.toggle('show');
    document.querySelector('.user-select-btn').classList.toggle('active');
}

function renderUserList() {
    const data = loadData();
    const container = document.getElementById('user-list-container');
    if (!container) return;
    const colors = ['linear-gradient(135deg,#667eea,#764ba2)', 'linear-gradient(135deg,#FF9A63,#E87A4E)', 'linear-gradient(135deg,#43E97B,#38F9D7)'];
    container.innerHTML = data.users.length === 0 
        ? '<div style="padding:12px;text-align:center;color:var(--text-light);">暂无用户，请创建新账号</div>'
        : data.users.map((u, i) => `
            <div class="user-select-item" onclick="quickLogin('${u.id}')">
                <div class="item-avatar" style="background:${colors[i%3]};color:white;">${u.name.charAt(0)}</div>
                <div class="item-info">
                    <div class="item-name">${u.name}</div>
                    <div class="item-grade">${gradeNames[u.grade]} · Lv.${u.difficulty}</div>
                </div>
            </div>
        `).join('');
}

function quickLogin(userId) {
    const data = loadData();
    const user = data.users.find(u => u.id === userId);
    if (!user) return;
    data.currentUser = userId;
    saveData(data);
    document.getElementById('selected-user-display').innerHTML = `<span>${user.name.charAt(0)}</span> ${user.name}`;
    document.getElementById('login-form-section').style.display = 'block';
    document.getElementById('login-difficulty').value = user.difficulty || 1;
    document.querySelector('.user-select-btn').dataset.userId = userId;
    document.getElementById('user-select-dropdown').classList.remove('show');
}

function handleLogin() {
    const data = loadData();
    const btn = document.querySelector('.user-select-btn');
    const userId = btn.dataset.userId;
    const difficulty = parseInt(document.getElementById('login-difficulty').value);
    if (userId) {
        const user = data.users.find(u => u.id === userId);
        if (user) { 
            user.difficulty = difficulty; 
            user.lastLogin = Date.now(); 
            data.currentUser = userId; 
            saveData(data); 
        }
    } else {
        showToast('请先选择学习者');
        return;
    }
    updateUI(); syncTodayStats(); showPage('home');
}

function showCreateUserModal() { document.getElementById('create-user-modal').classList.add('show'); }
function closeCreateUserModal() { document.getElementById('create-user-modal').classList.remove('show'); document.getElementById('create-name').value = ''; }

function createNewUser() {
    const name = document.getElementById('create-name').value.trim();
    const grade = parseInt(document.getElementById('create-grade').value);
    const difficulty = parseInt(document.getElementById('create-difficulty').value);
    if (!name) { showToast('请输入名字'); return; }
    const data = loadData();
    if (data.users.find(u => u.name === name)) { showToast('名字已存在'); return; }
    const user = {
        id: 'user_' + Date.now(), name, grade, difficulty, score: 0, lastLogin: Date.now(), createdAt: Date.now(),
        abilities: { attention: 65, memory: 60, logic: 70, creativity: 55, problem: 65, strategy: 60 },
        knowledge: { math: 30, chinese: 30, english: 30, physics: 30, chemistry: 30 },
        studyDays: {}, calendarData: {}, planTasks: {}, gameScores: {},
        uploads: { method: [], thinking: [], video: [] },
        userVideos: [], chatHistory: {}, thinkingScores: { logic: 0, creative: 0, critical: 0, system: 0 },
        practiceRecords: [], wrongNotes: [], aiChatCount: 0,
        todayStats: { date: new Date().toDateString(), questions: 0, correct: 0, minutes: 0 },
        // 母题相关
        topicResults: {}, // {topicId: {correct, wrong, lastTime}}
        wrongNoteIds: [], // 错题ID列表
        uploadedImages: [] // 上传的错题图片
    };
    data.users.push(user); data.currentUser = user.id; saveData(data);
    closeCreateUserModal(); updateUI(); showPage('home'); showToast('账号创建成功！');
}

function confirmClearAllData() {
    if(confirm('确定要清除所有数据吗？这将删除所有用户和学习记录！')) {
        clearAllData();
    }
}
function clearAllData() {
    if (!confirm('⚠️ 确定要清除所有数据吗？')) return;
    localStorage.removeItem(STORAGE_KEY); location.reload();
}

// ====== UI更新 ======
function updateUI() {
    const user = getCurrentUserData();
    if (!user) return;
    document.getElementById('greeting-name').textContent = user.name;
    document.getElementById('difficulty-text').textContent = 'Lv.' + user.difficulty;
    document.getElementById('header-avatar').textContent = user.name.charAt(0);
    document.getElementById('dropdown-name').textContent = user.name;
    document.getElementById('dropdown-info').textContent = `${gradeNames[user.grade]} · Lv.${user.difficulty}`;
}

function syncTodayStats() {
    const user = getCurrentUserData();
    if (!user) return;
    const today = new Date().toDateString();
    let todayStats = user.todayStats || { date: today, questions: 0, correct: 0, minutes: 0 };
    if (todayStats.date !== today) { todayStats = { date: today, questions: 0, correct: 0, minutes: 0 }; user.todayStats = todayStats; syncUserData(user); }
    document.getElementById('today-questions').textContent = user.aiChatCount || 0;
    document.getElementById('today-correct').textContent = todayStats.questions > 0 ? Math.round(todayStats.correct / todayStats.questions * 100) + '%' : '0%';
    document.getElementById('today-minutes').textContent = todayStats.minutes || 0;
    const studyDays = user.studyDays || {};
    let streak = 0;
    for (let i = 0; i < 365; i++) {
        const d = new Date(); d.setDate(d.getDate() - i);
        if (studyDays[d.toISOString().split('T')[0]]) streak++; else if (i > 0) break;
    }
    document.getElementById('today-streak').textContent = streak;
}

// ====== 页面切换 ======
function showPage(pageId) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const target = document.getElementById('page-' + pageId);
    if (target) target.classList.add('active');
    // 登录页面隐藏底部导航
    const bottomNav = document.querySelector('.bottom-nav');
    if (bottomNav) {
        bottomNav.style.display = pageId === 'login' ? 'none' : 'flex';
    }
}

function closeFullscreenPage() { document.getElementById('fullscreen-container').classList.remove('active'); }
function toggleUserMenu() { document.getElementById('user-dropdown').classList.toggle('show'); }

function showUserSwitchModal() {
    closeUserMenu();
    const data = loadData();
    const container = document.getElementById('switch-user-list');
    container.innerHTML = data.users.map(u => `
        <div class="user-select-item" onclick="switchToUser('${u.id}')" style="${u.id === data.currentUser ? 'background:#f0f7ff;' : ''}">
            <div class="item-avatar" style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;">${u.name.charAt(0)}</div>
            <div class="item-info">
                <div class="item-name">${u.name} ${u.id === data.currentUser ? '(当前)' : ''}</div>
                <div class="item-grade">${gradeNames[u.grade]} · Lv.${u.difficulty}</div>
            </div>
        </div>
    `).join('');
    document.getElementById('user-switch-modal').classList.add('show');
}

function closeUserSwitchModal() { document.getElementById('user-switch-modal').classList.remove('show'); }
function switchToUser(userId) { const data = loadData(); data.currentUser = userId; saveData(data); closeUserSwitchModal(); updateUI(); syncTodayStats(); }
function logoutAndReturn() { closeUserMenu(); showPage('login'); initLoginPage(); }

function openDifficultyModal() {
    const user = getCurrentUserData();
    document.querySelectorAll('.level-btn').forEach(btn => {
        const lvl = parseInt(btn.dataset.level);
        btn.style.borderColor = lvl === (user?.difficulty || 1) ? '#3377FF' : '#ddd';
        btn.style.background = lvl === (user?.difficulty || 1) ? '#e8f4ff' : 'white';
    });
    document.getElementById('difficulty-modal').classList.add('show');
}
function closeDifficultyModal() { document.getElementById('difficulty-modal').classList.remove('show'); }
function setDifficulty(level) {
    const data = loadData();
    const user = data.users.find(u => u.id === data.currentUser);
    if (user) { user.difficulty = level; saveData(data); updateUI(); }
    closeDifficultyModal();
}
function openSettingsPanel() { document.getElementById('settings-panel').style.display = 'flex'; }
function closeSettingsPanel(e) { if (e && e.target !== e.currentTarget) return; document.getElementById('settings-panel').style.display = 'none'; }
function showToast(msg) { const t = document.createElement('div'); t.className = 'toast'; t.textContent = msg; document.body.appendChild(t); setTimeout(() => t.remove(), 3000); }

