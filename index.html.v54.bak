    {id:516,title:'阅读理解',diff:3,q:'The main idea of paragraph 2 is...',a:'见短文',e:'找段落主题句'},
    {id:517,title:'完形填空',diff:3,q:'从A、B、C、D中选择最佳答案...',a:'见上下文',e:'上下文语境分析'},
