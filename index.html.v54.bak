function openFullscreenPage(pageId) {
    if (pageId === 'home') { closeFullscreenPage(); return; }
    const page = pageContent[pageId];
    if (!page) return;
    document.getElementById('fullscreen-title').textContent = page.title;
    document.getElementById('fullscreen-content').innerHTML = page.content;
    document.getElementById('fullscreen-container').classList.add('active');
    if (pageId === 'map') setTimeout(initMap, 100);
    if (pageId === 'topics') setTimeout(() => { initTopics(); updateTopicStats(); }, 100);
    if (pageId === 'plan') setTimeout(initPlan, 100);
}

// ====== DeepSeek API ======
async function callDeepSeek(messages, onChunk, onComplete) {
    try {
        const response = await fetch(DEEPSEEK_API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + DEEPSEEK_API_KEY },
            body: JSON.stringify({ model: DEEPSEEK_MODEL, messages: messages, stream: false }),
            signal: AbortSignal.timeout(30000)
        });
        if (!response.ok) throw new Error('API请求失败: ' + response.status);
        const data = await response.json();
        const content = data.choices?.[0]?.message?.content || '';
        if (onChunk && content) onChunk(content);
        if (onComplete) onComplete(content);
        const user = getCurrentUserData();
        if (user) { user.aiChatCount = (user.aiChatCount || 0) + 1; syncUserData(user); syncTodayStats(); }
        return content;
    } catch (error) {
        console.error('DeepSeek API错误:', error);
        const errMsg = error.message.includes('Failed to fetch') ? '网络连接失败，请检查网络' : '服务暂时不可用';
        if (onComplete) onComplete('抱歉，' + errMsg + '。您可以点击设置查看充值方法。');
        return null;
    }
}

async function handleChat(inputId, msgContainerId, userAvatar, botAvatar, systemPrompt) {
    const input = document.getElementById(inputId);
    const container = document.getElementById(msgContainerId);
    if (!input || !container) return;
    const message = input.value.trim();
    if (!message) return;
    container.innerHTML += `<div class="chat-msg user"><div class="chat-avatar" style="background:linear-gradient(135deg,#FF9A63,#E87A4E);">${userAvatar}</div><div class="chat-bubble">${message}</div></div>`;
    input.value = '';
    const aiId = 'ai-' + Date.now();
    container.innerHTML += `<div class="chat-msg" id="${aiId}"><div class="chat-avatar">${botAvatar}</div><div class="chat-bubble"><span class="ai-loading">正在思考</span></div></div>`;
    container.scrollTop = container.scrollHeight;
    await callDeepSeek([{role:'system',content:systemPrompt||'你是友好的AI学习助手'}, {role:'user',content:message}], null, (content) => {
        document.getElementById(aiId).querySelector('.chat-bubble').innerHTML = content.replace(/\n/g, '<br>');
        container.scrollTop = container.scrollHeight;
    });
}

function insertDeepseekMsg(text) { document.getElementById('deepseek-input').value = text; }
async function sendDeepseekMsg() { await handleChat('deepseek-input', 'deepseek-messages', '👤', '🤖', '你是友好的AI学习助手，擅长解答各学科问题，请给出详细解答。'); }
function insertTeacherMsg(text) { document.getElementById('teacher-input').value = text; }
async function sendTeacherMsg() { await handleChat('teacher-input', 'teacher-messages', '👤', '📐', '你是一位经验丰富的学科老师，擅长教学辅导，用通俗易懂的方式讲解。'); }
function selectTeacher(subject, el) {
    document.querySelectorAll('.teacher-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
    const subs = {math:'数学',chinese:'语文',english:'英语',physics:'物理',chemistry:'化学'};
    const avs = {math:'📐',chinese:'📝',english:'📖',physics:'⚡',chemistry:'🧪'};
    document.getElementById('teacher-messages').innerHTML = `<div class="chat-msg"><div class="chat-avatar">${avs[subject]}</div><div class="chat-bubble">同学你好！我是${subs[subject]}老师，擅长${subs[subject]}辅导。有什么${subs[subject]}问题可以问我哦！😊</div></div>`;
}

// ====== 认知地图 ======
function initMap() {
    const user = getCurrentUserData() || {};
    const abilities = user.abilities || {attention:65,memory:60,logic:70,creativity:55,problem:65,strategy:60};
    const knowledge = user.knowledge || {math:30,chinese:30,english:30,physics:0,chemistry:0};
    ['attention','memory','logic','creativity','problem','strategy'].forEach((k,i) => {
        const el = document.getElementById('radar-'+k);
        if (el) el.textContent = abilities[k] || 0;
    });
    document.getElementById('know-math').textContent = (knowledge.math||0)+'%';
    document.getElementById('know-chinese').textContent = (knowledge.chinese||0)+'%';
    document.getElementById('know-english').textContent = (knowledge.english||0)+'%';
    document.getElementById('know-physics').textContent = (knowledge.physics||0)+'%';
    document.getElementById('know-chemistry').textContent = (knowledge.chemistry||0)+'%';
    drawRadar(abilities);
    initStudyCalendar();
}

function drawRadar(abilities) {
    const canvas = document.getElementById('radar-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const w = canvas.width, h = canvas.height, cx = w/2, cy = h/2+10, r = Math.min(w,h)/2-30;
    const labels = ['注意力','记忆力','逻辑思维','创造力','问题解决','学习策略'];
    const values = [abilities.attention||0, abilities.memory||0, abilities.logic||0, abilities.creativity||0, abilities.problem||0, abilities.strategy||0];
    const colors = ['#3377FF','#43E97B','#FF9A63','#9B59B6','#3498db','#f1c40f'];
    ctx.clearRect(0,0,w,h);
    for (let level=1; level<=4; level++) {
        ctx.beginPath();
        for (let i=0; i<=6; i++) {
            const angle = i*Math.PI*2/6 - Math.PI/2;
            const x = cx + r*(level/4)*Math.cos(angle);
            const y = cy + r*(level/4)*Math.sin(angle);
            if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
        }
        ctx.strokeStyle = 'rgba(0,0,0,0.1)'; ctx.stroke();
    }
    for (let i=0; i<6; i++) {
        const angle = i*Math.PI*2/6 - Math.PI/2;
        ctx.beginPath();
        ctx.moveTo(cx,cy); ctx.lineTo(cx+r*Math.cos(angle),cy+r*Math.sin(angle));
        ctx.strokeStyle='rgba(0,0,0,0.15)'; ctx.stroke();
        ctx.fillStyle='#666'; ctx.font='10px sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
        ctx.fillText(labels[i], cx+(r+18)*Math.cos(angle), cy+(r+18)*Math.sin(angle));
    }
    ctx.beginPath();
    for (let i=0; i<6; i++) {
        const angle = i*Math.PI*2/6 - Math.PI/2;
        const v = Math.min(100,Math.max(0,values[i]))/100;
        const x = cx + r*v*Math.cos(angle), y = cy + r*v*Math.sin(angle);
        if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.closePath(); ctx.fillStyle='rgba(51,119,255,0.25)'; ctx.fill();
    ctx.strokeStyle='#3377FF'; ctx.lineWidth=2; ctx.stroke();
    for (let i=0; i<6; i++) {
        const angle = i*Math.PI*2/6 - Math.PI/2;
        const v = Math.min(100,Math.max(0,values[i]))/100;
        ctx.beginPath(); ctx.arc(cx+r*v*Math.cos(angle),cy+r*v*Math.sin(angle),4,0,Math.PI*2);
        ctx.fillStyle=colors[i]; ctx.fill();
    }
}

function initStudyCalendar() {
    const user = getCurrentUserData() || {};
    const studyDays = user.studyDays || {};
    const container = document.getElementById('study-calendar');
    if (!container) return;
    const today = new Date();
    let html = '';
    for (let i=29; i>=0; i--) {
        const d = new Date(today); d.setDate(d.getDate()-i);
        const dateStr = d.toISOString().split('T')[0];
        const minutes = studyDays[dateStr] || 0;
        const intensity = Math.min(1, minutes/60);
        const color = `rgba(67,233,123,${0.15+intensity*0.7})`;
        html += `<div style="height:24px;background:${color};border-radius:4px;"></div>`;
    }
    container.innerHTML = html;
}

// ====== 学习计划 ======
function initPlan() {
    const container = document.getElementById('plan-calendar-grid');
    if (!container) return;
    const today = new Date();
    const year = today.getFullYear();
    const month = today.getMonth();
    document.getElementById('plan-month').textContent = `${year}年${month+1}月`;
    const firstDay = new Date(year,month,1).getDay();
    const daysInMonth = new Date(year,month+1,0).getDate();
    let html = '';
    for (let i=0; i<firstDay; i++) html += '<div class="calendar-day disabled"></div>';
    for (let d=1; d<=daysInMonth; d++) {
        const isToday = d === today.getDate();
        html += `<div class="calendar-day ${isToday?'today':''}" onclick="this.classList.toggle('checked')">${d}</div>`;
    }
    container.innerHTML = html;
}

// ====== 母题训练 ======
let currentGrade = 7;
let currentSubject = 'math';
let currentTopics = [];

function initTopics() {
    document.getElementById('topic-total').textContent = getTotalTopicCount();
    filterTopics(7);
}

function updateTopicStats() {
    const user = getCurrentUserData() || {};
    const results = user.topicResults || {};
    const wrongNoteIds = user.wrongNoteIds || [];
    const done = Object.keys(results).length;
    let correct = 0;
    Object.values(results).forEach(r => { if (r.correct) correct++; });
    document.getElementById('topic-done').textContent = done;
    document.getElementById('topic-accuracy').textContent = done > 0 ? Math.round(correct/done*100)+'%' : '0%';
    document.getElementById('topic-wrong').textContent = wrongNoteIds.length;
    document.getElementById('wrong-note-count').textContent = wrongNoteIds.length;
}

function filterTopics(grade, el) {
    if (el) {
        document.querySelectorAll('.grade-tab-btn').forEach(b => b.classList.remove('active'));
        el.classList.add('active');
    }
    currentGrade = grade;
    const subjects = Object.keys(allTopics[grade] || {});
    currentSubject = subjects[0] || 'math';
    document.querySelectorAll('.subject-tab-btn').forEach((b,i) => {
        b.classList.toggle('active', subjects[i] === currentSubject);
    });
    filterSubjects(currentSubject);
}

function filterSubjects(subject, el) {
    if (el) {
        document.querySelectorAll('.subject-tab-btn').forEach(b => b.classList.remove('active'));
        el.classList.add('active');
    }
    currentSubject = subject;
    const topics = allTopics[currentGrade]?.[subject] || [];
    currentTopics = topics;
    const container = document.getElementById('topics-list');
    if (!container) return;
    if (topics.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-light);">该模块暂无题目</div>';
        return;
    }
    const gradients = ['linear-gradient(135deg,#3377FF,#66A3FF)','linear-gradient(135deg,#43E97B,#7CE7A0)','linear-gradient(135deg,#FF9A63,#FFB088)','linear-gradient(135deg,#667eea,#764ba2)'];
    container.innerHTML = topics.map((t,i) => `
        <div class="topic-card" onclick="startPractice(${t.id})">
            <div class="topic-header" style="background:${gradients[i%4]};">
                <div class="topic-title">${t.title}</div>
                <div class="topic-subtitle">${'★'.repeat(t.diff)}</div>
            </div>
            <div class="topic-footer">
                <div class="topic-difficulty">难度: ${'★'.repeat(t.diff)}</div>
                <div style="color:var(--blue);font-size:12px;">开始练习 →</div>
            </div>
        </div>
    `).join('');
}

function findTopic(id) {
    for (const grade in allTopics) {
        for (const subject in allTopics[grade]) {
            const found = allTopics[grade][subject].find(t => t.id === id);
            if (found) return found;
        }
    }
    return null;
}

function startPractice(topicId) {
    const topic = findTopic(topicId);
    if (!topic) return;
    const user = getCurrentUserData() || {};
    const result = user.topicResults?.[topicId];
    const content = document.getElementById('detail-content');
    content.innerHTML = `
        <div style="font-size:16px;font-weight:bold;margin-bottom:16px;">📚 ${topic.title}</div>
        <div class="practice-card">
            <div class="practice-question">${topic.q}</div>
            <div class="practice-input">
                <input type="text" id="practice-answer" placeholder="输入你的答案..."/>
                <button onclick="checkAnswer(${topicId})">提交</button>
            </div>
            <div id="practice-result"></div>
        </div>
        <div style="margin-top:16px;">
            <button class="camera-btn" onclick="document.getElementById('topic-photo').click()">📷 拍照上传错题</button>
            <input type="file" id="topic-photo" accept="image/*" capture="environment" style="display:none" onchange="uploadTopicPhoto(${topicId},this)">
        </div>
        <button class="login-btn login-btn-primary" style="margin-top:12px;" onclick="requestAITopicExplanation(${topicId})">🤖 AI智能解说</button>
        <div id="ai-explanation-area" style="display:none;margin-top:12px;padding:12px;background:#f0f7ff;border-radius:12px;">
            <div style="font-size:12px;color:var(--blue);margin-bottom:8px;">🤖 AI解说</div>
            <div id="ai-explanation-text" style="font-size:14px;"></div>
        </div>
        <button class="login-btn login-btn-secondary" style="margin-top:12px;" onclick="closeDetail()">关闭</button>
    `;
    document.getElementById('detail-modal').classList.add('show');
}

function checkAnswer(topicId) {
    const topic = findTopic(topicId);
    if (!topic) return;
    const input = document.getElementById('practice-answer');
    const resultDiv = document.getElementById('practice-result');
    const userAnswer = input.value.trim().toLowerCase().replace(/\s/g,'');
    const correctAnswer = topic.a.toLowerCase().replace(/\s/g,'');
    const isCorrect = userAnswer === correctAnswer || userAnswer.includes(correctAnswer) || correctAnswer.includes(userAnswer);
    if (isCorrect) {
        resultDiv.innerHTML = '<div class="practice-result correct">✓ 回答正确！<div class="explanation">答案：<span class="answer-highlight">'+topic.a+'</span></div><div class="explanation">'+topic.e+'</div></div>';
    } else {
        resultDiv.innerHTML = '<div class="practice-result wrong">✗ 回答错误<div class="explanation">正确答案：<span class="answer-highlight">'+topic.a+'</span></div><div class="explanation">'+topic.e+'</div></div>';
    }
    // 保存结果
    const user = getCurrentUserData() || {};
    user.topicResults = user.topicResults || {};
    user.topicResults[topicId] = { correct: isCorrect, wrong: !isCorrect, lastTime: Date.now() };
    if (!isCorrect) {
        user.wrongNoteIds = user.wrongNoteIds || [];
        if (!user.wrongNoteIds.includes(topicId)) {
            user.wrongNoteIds.push(topicId);
            user.wrongNotes = user.wrongNotes || [];
            if (!user.wrongNotes.find(n => n.topicId === topicId)) {
                user.wrongNotes.push({ topicId, question: topic.q, answer: topic.a, time: Date.now() });
            }
        }
    }
    user.todayStats = user.todayStats || { questions: 0, correct: 0 };
    user.todayStats.questions++;
    if (isCorrect) user.todayStats.correct++;
    syncUserData(user);
    updateTopicStats();
}

async function requestAITopicExplanation(topicId) {
    const topic = findTopic(topicId);
    if (!topic) return;
    const area = document.getElementById('ai-explanation-area');
    const text = document.getElementById('ai-explanation-text');
    if (!area || !text) return;
    area.style.display = 'block';
    text.innerHTML = '<span class="ai-loading">正在生成AI解说</span>';
    await callDeepSeek([
        {role:'system',content:'你是数学辅导老师，请详细解释题目解题思路。'},
        {role:'user',content:`请详细讲解这道题目：${topic.q}\n答案是：${topic.a}\n请给出详细的解题思路、解题技巧和举一反三的练习。`}
    ], null, (content) => { text.innerHTML = content.replace(/\n/g,'<br>'); });
}

function uploadTopicPhoto(topicId, input) {
    if (!input.files[0]) return;
    const user = getCurrentUserData() || {};
    user.uploadedImages = user.uploadedImages || [];
    const reader = new FileReader();
    reader.onload = function(e) {
        user.uploadedImages.push({ id: Date.now(), topicId, image: e.target.result, time: Date.now() });
        syncUserData(user);
        showToast('错题照片上传成功！');
    };
    reader.readAsDataURL(input.files[0]);
    input.value = '';
}

function showWrongNotes() {
    const user = getCurrentUserData() || {};
    const wrongNotes = user.wrongNotes || [];
    const content = document.getElementById('detail-content');
    if (wrongNotes.length === 0) {
        content.innerHTML = `
            <div style="font-size:18px;font-weight:bold;margin-bottom:16px;">📝 错题本</div>
            <div style="text-align:center;padding:40px;color:var(--text-light);">
                <div style="font-size:48px;margin-bottom:12px;">✨</div>
                <div>暂无错题记录</div>
                <div style="font-size:12px;margin-top:4px;">继续保持，加油！</div>
            </div>
            <button class="login-btn login-btn-secondary" onclick="closeDetail()">关闭</button>
        `;
    } else {
        content.innerHTML = `
            <div style="font-size:18px;font-weight:bold;margin-bottom:16px;">📝 错题本 (${wrongNotes.length}道)</div>
            <div style="max-height:400px;overflow-y:auto;">
                ${wrongNotes.map(n => `
                    <div class="wrong-note-card" onclick="startPractice(${n.topicId})">
                        <div class="wrong-note-question">${n.question}</div>
                        <div class="wrong-note-answer">答案：${n.answer}</div>
                    </div>
                `).join('')}
            </div>
            <button class="login-btn login-btn-secondary" onclick="closeDetail()">关闭</button>
        `;
    }
    document.getElementById('detail-modal').classList.add('show');
}

function closeDetail() { document.getElementById('detail-modal').classList.remove('show'); }

// ====== 思维训练 ======
const thinkingQuestions = {
    logic: [
        {q:'如果A>B，B>C，那么A和C的关系是？',opts:['A>C','A<C','A=C','无法确定'],a:0},
        {q:'找规律：2, 4, 8, 16, ?',opts:['20','24','32','30'],a:2},
        {q:'小明比小华高，小红比小华矮，谁最高？',opts:['小明','小华','小红','一样高'],a:0}
    ],
    creative: [
        {q:'列举砖头的3种创意用途'},
        {q:'如何让学习变得更有趣？说出你的想法'},
        {q:'如果你是校长，会做哪些改变？'}
    ],
    critical: [
        {q:'有人说"玩游戏浪费时间"，你同意吗？说出你的观点'},
        {q:'新闻说"XX公司业绩增长200%"，你怎么看？'}
    ],
    system: [
        {q:'分析学校食堂的问题及解决方案'},
        {q:'如何优化你的学习方法？'}
    ]
};

let currentThinkingType = 'logic';

function startThinking(type) {
    currentThinkingType = type;
    const questions = thinkingQuestions[type];
    const q = questions[Math.floor(Math.random() * questions.length)];
    const typeNames = {logic:'逻辑思维',creative:'创意思维',critical:'批判思维',system:'系统思维'};
    const area = document.getElementById('thinking-area');
    if (!area) return;
    if (q.opts) {
        area.innerHTML = `
            <div class="thinking-card">
                <div class="thinking-header">
                    <div class="thinking-icon" style="background:rgba(102,126,234,0.2);">📐</div>
                    <div class="thinking-title">${typeNames[type]}训练</div>
                </div>
                <div class="thinking-question">${q.q}</div>
                <div class="thinking-options">
                    ${q.opts.map((o,i) => `<div class="thinking-option" onclick="selectThinkingOpt(this,${i},${q.a},${type})">${o}</div>`).join('')}
                </div>
            </div>
        `;
    } else {
        area.innerHTML = `
            <div class="thinking-card">
                <div class="thinking-header">
                    <div class="thinking-icon" style="background:rgba(102,126,234,0.2);">📐</div>
                    <div class="thinking-title">${typeNames[type]}训练</div>
                </div>
                <div class="thinking-question">${q.q}</div>
                <textarea class="input-field" id="thinking-answer" placeholder="输入你的想法..." rows="3" style="margin-bottom:12px;"></textarea>
                <button class="game-btn btn-blue" onclick="submitThinkingAnswer('${type}')">提交答案</button>
            </div>
        `;
    }
}

function selectThinkingOpt(el, selected, correct, type) {
    document.querySelectorAll('.thinking-option').forEach(o => { o.classList.remove('selected','correct','wrong'); o.onclick=null; });
    el.classList.add('selected');
    setTimeout(() => {
        if (selected === correct) { el.classList.add('correct'); }
        else { el.classList.add('wrong'); document.querySelectorAll('.thinking-option')[correct].classList.add('correct'); }
    }, 300);
}

function submitThinkingAnswer(type) {
    const answer = document.getElementById('thinking-answer')?.value.trim();
    if (!answer) { showToast('请输入答案'); return; }
    showToast('答案已提交！');
    const user = getCurrentUserData();
    if (user) {
        user.thinkingScores = user.thinkingScores || {logic:0,creative:0,critical:0,system:0};
        user.thinkingScores[type] = Math.min(100, (user.thinkingScores[type]||0) + 5);
        syncUserData(user);
    }
}

// ====== 学霸方法详情 ======
const methodDetails = {
    feyman: {title:'🧠 费曼学习法',desc:'把学到的知识用自己的话讲给别人听，如果别人能听懂，说明你真正掌握了。',steps:['选择一个你想要理解的概念','想象你要把这个概念教给一个完全不懂的人','如果讲解过程中卡住了，就回顾原始材料','用自己的话重新组织，确保通俗易懂'],tip:'💡 最佳实践：每天用费曼学习法复习一个知识点，坚持21天形成习惯。'},
    pomodoro: {title:'⏰ 番茄工作法',desc:'25分钟专注学习，5分钟休息，循环进行，提高效率。',steps:['选择一个待完成的任务','设定25分钟倒计时（一个番茄钟）','专注工作，中途不做其他事','计时结束后休息5分钟','每4个番茄钟后休息15-30分钟'],tip:'💡 建议：使用手机闹钟或专门的番茄钟APP来计时。'},
    ebbinghaus: {title:'🔄 艾宾浩斯记忆法',desc:'学习后1天、3天、7天、14天、30天分别复习，加深长期记忆。',steps:['初次学习新知识','24小时后进行第一次复习','3天后再复习一次','7天后第三次复习','14天后第四次复习','30天后最后一次复习'],tip:'💡 关键：严格按照时间节点复习，不要偷懒！'},
    mindmap: {title:'🎨 思维导图法',desc:'用图形和关键词将知识点连接起来，形成系统化的知识结构。',steps:['在纸中央写下核心主题','从中心向外画出主分支','在每个主分支写上关键词','从关键词继续延伸子分支','用不同颜色区分不同主题','添加图标和符号增强记忆'],tip:'💡 工具推荐：可以使用XMind、幕布等软件制作数字思维导图。'},
    cornell: {title:'📝 康奈尔笔记法',desc:'将笔记分为要点、线索、总结三个区域，提高复习效率。',steps:['把笔记页面分为三部分','右侧大的区域记录主要内容','左侧区域记录提示词/关键词','底部区域写总结和问题','用笔记时遮住右侧，回忆内容','用总结区进行自测'],tip:'💡 最佳使用场景：课堂笔记、读书笔记、讲座记录。'},
    sq3r: {title:'📖 SQ3R阅读法',desc:'Survey泛读、Question提问、Read阅读、Recite复述、Review复习。',steps:['Survey（泛读）：快速浏览标题、目录、图表','Question（提问）：写下你想知道的问题','Read（阅读）：仔细阅读章节内容','Recite（复述）：合上书复述要点','Review（复习）：定期回顾已读内容'],tip:'💡 适合：教科书、论文、长篇文章的阅读。'}
};

function showMethodDetail(id) {
    const m = methodDetails[id];
    if (!m) return;
    const content = document.getElementById('detail-content');
    content.innerHTML = `
        <div style="text-align:center;margin-bottom:16px;">
            <div style="font-size:48px;margin-bottom:8px;">${m.title.split(' ')[0]}</div>
            <div style="font-size:18px;font-weight:bold;">${m.title.split(' ').slice(1).join(' ')}</div>
        </div>
        <div style="background:#f5f7ff;padding:12px;border-radius:10px;margin-bottom:16px;font-size:14px;">${m.desc}</div>
        <div style="font-size:14px;font-weight:600;margin-bottom:10px;">📋 具体步骤：</div>
        ${m.steps.map((s,i) => `<div style="display:flex;gap:10px;margin-bottom:8px;"><div style="width:22px;height:22px;background:var(--blue);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">${i+1}</div><div style="font-size:13px;color:var(--text-gray);">${s}</div></div>`).join('')}
        <div style="background:#fff3cd;padding:12px;border-radius:10px;font-size:12px;color:#856404;margin-top:16px;">${m.tip}</div>
        <button class="login-btn login-btn-primary" style="margin-top:16px;" onclick="closeDetail()">我学会了</button>
    `;
    document.getElementById('detail-modal').classList.add('show');
}

// ====== 播客 ======
function filterPodcast(category, el) {
    document.querySelectorAll('.grade-tab-btn').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
}

function playPodcast(title) {
    showToast('播放：' + title);
}

// ====== 视频 ======
let vpVideo = null, vpPlaying = false;

function playVideo(title, url) {
    document.getElementById('vp-title').textContent = title;
    document.getElementById('video-player-modal').classList.add('show');
    vpVideo = document.getElementById('vp-video');
    vpVideo.src = url;
    vpVideo.onloadedmetadata = () => { document.getElementById('vp-time').textContent = '0:00 / ' + formatTime(vpVideo.duration); };
    vpVideo.ontimeupdate = () => {
        if (vpVideo.duration) {
            document.getElementById('vp-progress-bar').style.width = (vpVideo.currentTime/vpVideo.duration*100) + '%';
            document.getElementById('vp-time').textContent = formatTime(vpVideo.currentTime) + ' / ' + formatTime(vpVideo.duration);
        }
    };
    vpVideo.onplay = () => { vpPlaying = true; document.getElementById('vp-play-btn').textContent = '⏸'; };
    vpVideo.onpause = () => { vpPlaying = false; document.getElementById('vp-play-btn').textContent = '▶'; };
    vpVideo.play();
}

function toggleVpPlay() { if (!vpVideo) return; vpPlaying ? vpVideo.pause() : vpVideo.play(); }
function seekVideo(e) { if (!vpVideo || !vpVideo.duration) return; const rect = e.target.getBoundingClientRect(); vpVideo.currentTime = ((e.clientX-rect.left)/rect.width)*vpVideo.duration; }
function closeVideoPlayer() { if (vpVideo) { vpVideo.pause(); vpVideo.src = ''; } document.getElementById('video-player-modal').classList.remove('show'); }
function formatTime(s) { if (!s||isNaN(s)) return '0:00'; return Math.floor(s/60)+':'+(Math.floor(s%60)+'').padStart(2,'0'); }

function handleVideoUpload(input) {
    if (!input.files[0]) return;
    const url = URL.createObjectURL(input.files[0]);
    const user = getCurrentUserData();
    if (user) { user.userVideos = user.userVideos||[]; user.userVideos.push({id:Date.now(),title:input.files[0].name,url,time:Date.now()}); syncUserData(user); }
    playVideo(input.files[0].name, url);
    showToast('视频上传成功！');
    input.value = '';
}

function handlePracticePhoto(input) {
    if (!input.files[0]) return;
    showToast('正在分析错题...');
    setTimeout(() => { showToast('AI分析功能开发中，请先练习母题'); }, 1500);
    input.value = '';
}

// ====== 游戏 ======
let gameScore = 0, gameType = '', gameLevel = 1, gameTimer = null, gameStartTime = 0, schulteNext = 1;

function startGame(type) {
    gameType = type; gameScore = 0; gameLevel = 1;
    // 显示全屏游戏区域
    const gameFullscreen = document.getElementById('game-fullscreen-container');
    if (gameFullscreen) {
        gameFullscreen.style.display = 'flex';
        document.getElementById('game-area').style.display = 'block';
    } else {
        document.getElementById('game-area').style.display = 'block';
    }
    document.getElementById('game-score').textContent = '0';
    switch(type) {
        case 'schulte': startSchulte(); break;
        case 'visual': startVisual(); break;
        case 'digit': startDigit(); break;
        case 'pattern': startPattern(); break;
        case 'tap': startTap(); break;
        case 'color': startColor(); break;
        case 'diff': startDiff(); break;
        case 'reason': startReason(); break;
    }
}

function startSchulte() {
    document.getElementById('game-title').textContent = '🎯 舒尔特方格';
    const sizes = [3,4,5,6];
    const size = sizes[Math.min(gameLevel-1,3)];
    const nums = Array.from({length:size*size},(_,i)=>i+1).sort(()=>Math.random()-0.5);
    const board = document.getElementById('game-board');
    board.className = 'game-board size-'+size; board.style.display = 'grid';
    board.innerHTML = nums.map(n => `<div class="game-cell" onclick="checkSchulte(this,${n})" style="background:white;font-size:${28-size*2}px;font-weight:bold;cursor:pointer;">${n}</div>`).join('');
    schulteNext = 1; gameStartTime = Date.now();
    if (gameTimer) clearInterval(gameTimer);
    gameTimer = setInterval(() => { if (Date.now()-gameStartTime > 30000) { clearInterval(gameTimer); endGame(); } }, 1000);
}

function checkSchulte(el, n) {
    if (n === schulteNext) {
        el.style.background = '#43E97B'; el.style.color = 'white';
        gameScore++; document.getElementById('game-score').textContent = gameScore;
        schulteNext++;
        if (schulteNext > el.parentElement.children.length) {
            if (gameLevel < 4) { gameLevel++; startSchulte(); }
            else endGame();
        }
    } else { el.style.background = '#ff6b6b'; setTimeout(() => el.style.background = 'white', 200); }
}

function startVisual() {
    document.getElementById('game-title').textContent = '👁️ 视觉搜索';
    const board = document.getElementById('game-board');
    board.className = 'game-board size-4'; board.style.display = 'grid';
    const targetIdx = Math.floor(Math.random()*16);
    const colors = ['#FF6B6B','#4ECDC4','#45B7D1','#96CEB4'];
    const targetColor = colors[Math.floor(Math.random()*4)];
    const baseColor = colors.filter(c=>c!==targetColor)[0];
    board.innerHTML = Array.from({length:16},(_,i)=>`<div class="game-cell" onclick="checkVisual(this,${i},${targetIdx},'${targetColor}')" style="background:${i===targetIdx?targetColor:baseColor};border-radius:4px;cursor:pointer;"></div>`).join('');
    gameScore = 0; document.getElementById('game-score').textContent = '0';
}

function checkVisual(el, idx, targetIdx, targetColor) {
    if (idx === targetIdx) {
        gameScore++; document.getElementById('game-score').textContent = gameScore;
        if (gameScore >= 10) { gameLevel++; document.getElementById('game-title').textContent += ' Lv.'+gameLevel; }
        setTimeout(() => startVisual(), 300);
    }
}

function startDigit() {
    document.getElementById('game-title').textContent = '🔢 数字记忆';
    const board = document.getElementById('game-board');
    board.className = 'game-board size-1'; board.style.cssText = 'display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:200px;';
    const count = 3 + gameLevel;
    const digits = Array.from({length:count},()=>Math.floor(Math.random()*10)).join('');
    board.innerHTML = `<div style="font-size:48px;font-weight:bold;color:var(--blue);letter-spacing:8px;">${digits}</div><div style="margin-top:20px;font-size:14px;color:var(--text-gray);">记住这些数字！</div>`;
    gameScore = 0; document.getElementById('game-score').textContent = '0';
    setTimeout(() => {
        board.innerHTML = `<div style="font-size:18px;color:var(--text-gray);margin-bottom:12px;">请输入你看到的数字：</div><input type="text" id="digit-input" class="input-field" style="text-align:center;font-size:24px;" maxlength="${count}"/><button class="game-btn btn-blue" style="margin-top:16px;" onclick="checkDigit('${digits}')">确认</button>`;
    }, 1500+count*200);
}

function checkDigit(correct) {
    const input = document.getElementById('digit-input');
    if (input && input.value === correct) { gameScore++; document.getElementById('game-score').textContent = gameScore; }
    setTimeout(() => startDigit(), 500);
}

let patternCorrect = [], patternFound = [];
function startPattern() {
    document.getElementById('game-title').textContent = '🎨 图形记忆';
    const board = document.getElementById('game-board');
    board.className = 'game-board size-4'; board.style.display = 'grid';
    const emojis = ['🍎','🍊','🍋','🍇','🌸','🌺','⭐','🌙','🔥','💎','🎁','🎈'];
    const count = 4 + gameLevel;
    const selected = emojis.slice(0,count);
    board.innerHTML = selected.map(e => `<div class="game-cell" style="background:#f0f7ff;font-size:28px;">${e}</div>`).join('');
    gameScore = 0; document.getElementById('game-score').textContent = '0';
    setTimeout(() => {
        const shuffled = [...emojis,'🍀','🌈'].slice(0,12).sort(()=>Math.random()-0.5);
        patternCorrect = [...selected]; patternFound = [];
        board.innerHTML = shuffled.map(e => `<div class="game-cell" onclick="checkPattern(this,'${e}')" style="background:white;font-size:24px;cursor:pointer;">?</div>`).join('');
    }, 2000+count*300);
}

function checkPattern(el, emoji) {
    if (el.textContent === '?' && patternCorrect.includes(emoji) && !patternFound.includes(emoji)) {
        el.textContent = emoji; el.style.background = '#f0f7ff'; patternFound.push(emoji);
        if (patternFound.length === patternCorrect.length) {
            gameScore++; document.getElementById('game-score').textContent = gameScore;
            if (gameScore >= 2) gameLevel++;
            setTimeout(() => startPattern(), 500);
        }
    } else if (el.textContent === '?') { el.style.background = '#ff6b6b'; setTimeout(() => { el.textContent = '?'; el.style.background = 'white'; }, 300); }
}

function startTap() {
    document.getElementById('game-title').textContent = '⚡ 快速点击';
    const board = document.getElementById('game-board');
    board.className = 'game-board size-3'; board.style.cssText = 'display:grid;position:relative;min-height:200px;';
    board.innerHTML = Array(9).fill('<div class="game-cell" style="position:relative;"></div>').join('');
    gameScore = 0; document.getElementById('game-score').textContent = '0'; gameStartTime = Date.now();
    if (gameTimer) clearInterval(gameTimer);
    gameTimer = setInterval(() => {
        if (Date.now()-gameStartTime > 10000) { clearInterval(gameTimer); endGame(); return; }
        board.querySelectorAll('.game-cell').forEach(c => c.innerHTML = '');
        board.querySelectorAll('.game-cell')[Math.floor(Math.random()*9)].innerHTML = '<div onclick="event.stopPropagation();tapTarget(this)" style="width:100%;height:100%;background:var(--blue);border-radius:8px;cursor:pointer;"></div>';
    }, 800);
}

function tapTarget(el) { el.style.background = '#43E97B'; gameScore++; document.getElementById('game-score').textContent = gameScore; }

function startColor() {
    document.getElementById('game-title').textContent = '🌈 颜色识别';
    const board = document.getElementById('game-board');
    board.className = 'game-board size-1'; board.style.cssText = 'display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:200px;gap:16px;';
    const colorWords = [{w:'红',c:'#FF6B6B'},{w:'蓝',c:'#3377FF'},{w:'绿',c:'#43E97B'},{w:'黄',c:'#FFD93D'},{w:'紫',c:'#9B59B6'}];
    gameScore = 0; document.getElementById('game-score').textContent = '0'; gameStartTime = Date.now();
    if (gameTimer) clearInterval(gameTimer);
    gameTimer = setInterval(() => {
        if (Date.now()-gameStartTime > 30000) { clearInterval(gameTimer); endGame(); return; }
        const word = colorWords[Math.floor(Math.random()*5)];
        const wrongColor = colorWords.filter(c=>c.c!==word.c)[Math.floor(Math.random()*4)];
        board.innerHTML = `<div id="color-word" style="font-size:48px;font-weight:bold;padding:20px;color:${wrongColor.c}">${word.w}</div><div style="display:flex;gap:12px;margin-top:10px;"><button class="game-btn btn-blue" onclick="gameScore++;document.getElementById('game-score').textContent=gameScore;">正确</button><button class="game-btn btn-orange" onclick="gameScore++;document.getElementById('game-score').textContent=gameScore;">错误</button></div>`;
    }, 2500);
}

function startDiff() {
    document.getElementById('game-title').textContent = '🔍 找不同';
    const board = document.getElementById('game-board');
    board.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:16px;padding:10px;';
    const symbols = ['🌟','⭐','🌙','☀️','🔴','🔵'];
    const left = [...symbols]; const right = [...symbols];
    const diffIdx = Math.floor(Math.random()*6);
    right[diffIdx] = ['🟢','🟡','⬜','⬛'][Math.floor(Math.random()*4)];
    board.innerHTML = `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:12px;background:white;border-radius:12px;">${left.map(s=>`<div style="text-align:center;font-size:24px;">${s}</div>`).join('')}</div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;padding:12px;background:white;border-radius:12px;">${right.map((s,i)=>`<div style="text-align:center;font-size:24px;cursor:pointer;" onclick="checkDiff(this,${i},${diffIdx})">${s}</div>`).join('')}</div>`;
    gameScore = 0; document.getElementById('game-score').textContent = '0/1';
}

function checkDiff(el, idx, correctIdx) {
    if (idx === correctIdx) { gameScore++; document.getElementById('game-score').textContent = gameScore+'/1'; if (gameScore >= 3) gameLevel++; setTimeout(() => startDiff(), 500); }
}

function startReason() {
    document.getElementById('game-title').textContent = '🧩 图形推理';
    const board = document.getElementById('game-board');
    board.className = 'game-board size-1'; board.style.cssText = 'display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:250px;gap:16px;';
    const patterns = [{seq:['○','○○','○○○'],a:0,opt:['○○○○','○○○','○○○○○']},{seq:['△','△△','△△△'],a:1,opt:['△△','△△△','△△△△']},{seq:['□','□□','□□□'],a:2,opt:['□□','□□□','□□□□']}];
    const p = patterns[Math.min(gameLevel-1,2)];
    board.innerHTML = `<div style="display:flex;gap:8px;margin-bottom:12px;">${p.seq.map(s=>`<div style="padding:8px 12px;background:#f0f7ff;border-radius:8px;font-size:20px;">${s}</div>`).join('')}<div style="padding:8px 12px;background:#ddd;border-radius:8px;font-size:20px;">？</div></div><div style="display:flex;gap:12px;">${p.opt.map((o,i)=>`<button class="game-btn ${i===0?'btn-blue':i===1?'btn-orange':'btn-green'}" style="padding:10px 16px;font-size:16px;" onclick="checkReason(${i},${p.a})">${o}</button>`).join('')}</div>`;
    gameScore = 0; document.getElementById('game-score').textContent = '0';
}

function checkReason(selected, correct) { if (selected === correct) { gameScore++; document.getElementById('game-score').textContent = gameScore; if (gameScore >= 3) gameLevel++; } setTimeout(() => startReason(), 500); }

function endGame() {
    if (gameTimer) clearInterval(gameTimer);
    const timeSpent = Math.round((Date.now()-gameStartTime)/1000);
    const board = document.getElementById('game-board');
    board.style.cssText = 'display:flex;align-items:center;justify-content:center;min-height:200px;';
    board.innerHTML = `<div style="text-align:center;"><div style="font-size:48px;margin-bottom:12px;">🎉</div><div style="font-size:20px;font-weight:bold;color:var(--blue);">游戏结束！</div><div style="font-size:36px;font-weight:bold;margin:16px 0;">得分：${gameScore}</div><div style="font-size:14px;color:var(--text-gray);">用时：${timeSpent}秒 · 到达关卡 ${gameLevel}</div><div style="margin-top:20px;display:flex;gap:12px;justify-content:center;"><button class="game-btn btn-blue" onclick="resetGame()">再来一次</button><button class="game-btn btn-orange" onclick="closeGame()">返回</button></div></div>`;
    const user = getCurrentUserData();
    if (user) {
        user.gameScores = user.gameScores || {};
        user.gameScores[gameType] = Math.max(user.gameScores[gameType]||0, gameScore);
        user.todayStats = user.todayStats || { questions:0, correct:0, minutes:0 };
        user.todayStats.minutes += Math.ceil(timeSpent/60);
        const today = new Date().toISOString().split('T')[0];
        user.studyDays = user.studyDays || {};
        user.studyDays[today] = (user.studyDays[today]||0) + Math.ceil(timeSpent/60);
        syncUserData(user);
        syncTodayStats();
    }
}

function resetGame() { startGame(gameType); }
function closeGame() { 
    if (gameTimer) clearInterval(gameTimer); 
    document.getElementById('game-area').style.display = 'none';
    const gameFullscreen = document.getElementById('game-fullscreen-container');
    if (gameFullscreen) gameFullscreen.style.display = 'none';
}

