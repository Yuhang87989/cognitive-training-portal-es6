                    { id: 25, grade: 7, title: '一元一次方程', badge: '基础', methods: ['去分母', '去括号', '移项合并'], desc: '掌握一元一次方程的解法' },
                    { id: 26, grade: 7, title: '相交线与平行线', badge: '基础', methods: ['三线八角', '平行判定', '性质应用'], desc: '理解平行线的判定和性质' },
                    { id: 27, grade: 7, title: '二元一次方程组', badge: '进阶', methods: ['代入法', '加减法', '图像法'], desc: '消元思想解方程组' },
