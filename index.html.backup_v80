                    { id: 29, grade: 8, title: '一次函数', badge: '进阶', methods: ['图像法', '解析式法', '待定系数法'], desc: '理解函数概念与图像' },
                    { id: 30, grade: 8, title: '整式乘法与因式分解', badge: '进阶', methods: ['乘法公式', '提取公因式', '十字相乘'], desc: '掌握整式变形技巧' },
                    { id: 31, grade: 9, title: '一元二次方程', badge: '挑战', methods: ['配方法', '公式法', '因式分解法'], desc: '判别式与韦达定理' },
                    { id: 32, grade: 9, title: '相似三角形', badge: '挑战', methods: ['比例法', '平行线法', '射影定理'], desc: '相似形的判定与性质应用' },
                    { id: 33, grade: 9, title: '二次函数', badge: '挑战', methods: ['图像分析', '顶点公式', '实际应用'], desc: '二次函数的最值问题' },
                    { id: 34, grade: 9, title: '圆的基本性质', badge: '进阶', methods: ['弧弦角', '垂径定理', '圆周角定理'], desc: '圆与直线的位置关系' },
                    { id: 35, grade: 9, title: '概率统计', badge: '基础', methods: ['列举法', '树状图', '列表法'], desc: '概率计算与数据分析' }
