                    { id: 20, grade: 2, title: '看图写话', badge: '基础', methods: ['观察图片', '合理想象', '完整表达'], desc: '练习看图写句子' },
                    { id: 21, grade: 3, title: '比喻句', badge: '基础', methods: ['找相似点', '喻体选择', '比喻词运用'], desc: '理解并运用比喻修辞' },
