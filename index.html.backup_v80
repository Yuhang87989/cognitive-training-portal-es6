            generateAIQuestion('podcast', '播客学习内容');
        }


        function startPractice() {
            alert('开始针对性练习...');
        }
        
        // ==================== 游戏逻辑 ====================
        let schulteNumbers = [];
        let schulteCurrent = 1;
        let schulteStartTime = 0;
        let schulteTimer = null;
        let schulteGridSize = 4;
        
        // 舒尔特方格难度适配
        function applySchulteDifficulty() {
            const difficulty = getDifficulty();
            schulteGridSize = difficulty + 2; // 1级=3x3, 2级=4x4, 3级=5x5, 4级=6x6, 5级=7x7
            initSchulteGrid();
        }
        
        function initSchulteGrid() {
            const grid = document.getElementById('schulte-grid');
            const size = schulteGridSize;
            const total = size * size;
            
            grid.style.gridTemplateColumns = `repeat(${size}, 1fr)`;
            schulteNumbers = [];
            for (let i = 1; i <= total; i++) {
                schulteNumbers.push(i);
            }
            schulteNumbers.sort(() => Math.random() - 0.5);
            
            grid.innerHTML = '';
            schulteNumbers.forEach((num, idx) => {
                const cell = document.createElement('div');
                cell.className = 'schulte-cell';
                cell.textContent = num;
                cell.dataset.num = num;
                cell.style.fontSize = size > 5 ? '14px' : '18px';
                cell.onclick = () => clickSchulteCell(cell);
                grid.appendChild(cell);
            });
            
            schulteCurrent = 1;
            schulteStartTime = 0;
            clearInterval(schulteTimer);
            document.getElementById('schulte-start-btn').textContent = '开始训练';
            document.getElementById('schulte-start-btn').disabled = false;
        }
        
        function startSchulte() {
            const btn = document.getElementById('schulte-start-btn');
            if (btn.textContent === '开始训练') {
                schulteStartTime = Date.now();
                btn.textContent = '进行中...';
                btn.disabled = true;
                
                schulteTimer = setInterval(() => {
                    const elapsed = ((Date.now() - schulteStartTime) / 1000).toFixed(1);
                    document.querySelector('#page-game-attention .timer')?.remove();
                    const timer = document.createElement('div');
                    timer.className = 'timer';
                    timer.textContent = elapsed + 's';
                    document.querySelector('#page-game-attention .game-area').prepend(timer);
                }, 100);
            }
        }
        
        function clickSchulteCell(cell) {
            if (schulteStartTime === 0) return;
            
            const num = parseInt(cell.dataset.num);
            if (num === schulteCurrent) {
                cell.style.background = 'var(--primary-blue)';
                cell.style.color = 'white';
                schulteCurrent++;
                
                if (schulteCurrent > schulteGridSize * schulteGridSize) {
                    clearInterval(schulteTimer);
                    const elapsed = ((Date.now() - schulteStartTime) / 1000).toFixed(1);
                    const score = Math.round(1000 / parseFloat(elapsed) * schulteGridSize);
                    currentUser.score += score;
                    currentUser.todayTraining++;
                    document.getElementById('attention-score').textContent = currentUser.score.toLocaleString();
                    document.getElementById('stat-score').textContent = currentUser.score.toLocaleString();
                    document.getElementById('stat-today').textContent = currentUser.todayTraining;
                    
                    document.querySelector('#page-game-attention .game-area').innerHTML = 
                        `<div class="result-display">🎉 ${elapsed}s</div>
                         <div style="font-size: 16px; color: var(--text-gray);">+${score} 积分 (${schulteGridSize}×${schulteGridSize})</div>`;
                }
            } else {
                cell.style.background = '#F44336';
                cell.style.color = 'white';
            }
        }
        
        let memoryNumbers = [];
        let memorySequence = [];
        let memoryPhase = 'ready';
        let memoryCount = 6; // 默认记忆数量
        
        // 数字记忆难度适配
        function applyMemoryDifficulty() {
            const difficulty = getDifficulty();
            memoryCount = difficulty + 3; // 1级=4个, 2级=6个, 3级=8个, 4级=10个, 5级=12个
            initMemoryGrid();
        }
        
        function initMemoryGrid() {
            const grid = document.getElementById('memory-grid');
            grid.innerHTML = '';
            memoryNumbers = [];
            
            const count = memoryCount;
            for (let i = 0; i < count; i++) {
                const num = Math.floor(Math.random() * 9) + 1;
                memoryNumbers.push(num);
                
                const cell = document.createElement('div');
                cell.className = 'memory-cell';
                cell.dataset.idx = i;
                cell.onclick = () => clickMemoryCell(cell);
                cell.style.fontSize = count > 8 ? '16px' : '20px';
                grid.appendChild(cell);
            }
            
            memoryPhase = 'ready';
            document.getElementById('memory-start-btn').textContent = `开始训练(${memoryCount}个)`;
        }
        
        function startMemory() {
            const btn = document.getElementById('memory-start-btn');
            if (btn.textContent.includes('开始训练')) {
                btn.textContent = '记忆数字...';
                btn.disabled = true;
                
                const cells = document.querySelectorAll('#page-game-memory .memory-cell');
                cells.forEach((cell, idx) => {
                    cell.textContent = memoryNumbers[idx];
                    cell.classList.add('show');
                });
                
                const displayTime = Math.max(1500, 3000 - (memoryCount - 4) * 200); // 数字越多，显示时间越短
                setTimeout(() => {
                    cells.forEach(cell => {
                        cell.classList.remove('show');
                        cell.textContent = '';
                    });
                    
                    memorySequence = [Math.floor(Math.random() * memoryCount)];
                    cells[memorySequence[0]].textContent = memoryNumbers[memorySequence[0]];
                    cells[memorySequence[0]].classList.add('revealed');
                    
                    setTimeout(() => {
                        cells[memorySequence[0]].textContent = '?';
                        cells[memorySequence[0]].classList.remove('revealed');
                        btn.textContent = '请点击显示的数字';
                        btn.disabled = false;
                        memoryPhase = 'click';
                    }, displayTime);
                }, displayTime);
            }
        }
        
        function clickMemoryCell(cell) {
            if (memoryPhase !== 'click') return;
            
            const idx = parseInt(cell.dataset.idx);
            cell.textContent = memoryNumbers[idx];
            cell.classList.add('show');
            
            if (idx === memorySequence[0]) {
                cell.style.background = '#4CAF50';
                currentUser.score += 50;
            } else {
                cell.style.background = '#F44336';
            }
            
            document.getElementById('memory-score').textContent = currentUser.score.toLocaleString();
            document.getElementById('stat-score').textContent = currentUser.score.toLocaleString();
            currentUser.todayTraining++;
            document.getElementById('stat-today').textContent = currentUser.todayTraining;
            memoryPhase = 'done';
        }
        
        let reactionRound = 0;
        let reactionTimes = [];
        let reactionTimeout = null;
        let reactionStartTime = 0;
        let reactionDelay = 2000; // 基础延迟时间(毫秒)
        
        // 反应力训练难度适配
        function applyReactionDifficulty() {
            const difficulty = getDifficulty();
            // 难度越高，等待时间越短
            reactionDelay = 3500 - (difficulty - 1) * 500; // 1级=3.5s, 2级=3s, 3级=2.5s, 4级=2s, 5级=1.5s
        }
        
        function startReaction() {
            const btn = document.getElementById('reaction-start-btn');
            const hint = document.getElementById('reaction-hint');
            
            if (btn.textContent.includes('开始训练')) {
                reactionRound = 0;
                reactionTimes = [];
                btn.textContent = '准备...';
                btn.disabled = true;
                
                nextReactionRound();
            }
        }
        
        function nextReactionRound() {
            const hint = document.getElementById('reaction-hint');
            hint.textContent = '等待...';
            hint.style.color = 'var(--text-gray)';
            
            const delay = reactionDelay * 0.5 + Math.random() * reactionDelay;
            reactionTimeout = setTimeout(() => {
                hint.textContent = '点击!';
                hint.style.color = '#4CAF50';
                reactionStartTime = Date.now();
            }, delay);
        }
        
        function handleReactionClick() {
            const hint = document.getElementById('reaction-hint');
            const btn = document.getElementById('reaction-start-btn');
            
            if (hint.textContent === '等待...') {
                clearTimeout(reactionTimeout);
                hint.textContent = '太快了!';
                hint.style.color = '#F44336';
                setTimeout(nextReactionRound, 1000);
            } else if (hint.textContent === '点击!') {
                const time = Date.now() - reactionStartTime;
                reactionTimes.push(time);
                reactionRound++;
                
                if (reactionRound >= 5) {
                    const avgTime = Math.round(reactionTimes.reduce((a, b) => a + b) / 5);
                    const difficulty = getDifficulty();
                    const score = Math.max(0, 500 - avgTime + (difficulty - 1) * 50);
                    currentUser.score += score;
                    document.getElementById('reaction-score').textContent = currentUser.score.toLocaleString();
                    document.getElementById('stat-score').textContent = currentUser.score.toLocaleString();
                    currentUser.todayTraining++;
                    document.getElementById('stat-today').textContent = currentUser.todayTraining;
                    
                    hint.textContent = `平均 ${avgTime}ms`;
                    hint.style.color = 'var(--primary-blue)';
                    btn.textContent = '完成! +' + score + '积分';
                    btn.disabled = false;
                } else {
                    hint.textContent = time + 'ms';
                    hint.style.color = 'var(--primary-blue)';
                    setTimeout(nextReactionRound, 1000);
                }
            }
        }
        
        let observationPhase = 'ready';
        let observationTarget = -1;
        let observationRound = 0;
        let observationDifficulty = 3;
        
        // 观察力训练难度适配
        function applyObservationDifficulty() {
            const difficulty = getDifficulty();
            observationDifficulty = difficulty;
            initObservationGrid();
        }
        
        function initObservationGrid() {
            const grid = document.getElementById('observation-grid');
            grid.innerHTML = '';
            
            // 难度越高，格子越多
            const cellCount = observationDifficulty + 2; // 1级=3x3, 2级=4x4, 3级=5x5, 4级=6x6, 5级=7x7
            grid.style.gridTemplateColumns = `repeat(${cellCount}, 1fr)`;
            
            for (let i = 0; i < cellCount * cellCount; i++) {
                const cell = document.createElement('div');
                cell.className = 'observation-cell';
                cell.dataset.idx = i;
                cell.onclick = () => clickObservationCell(cell);
                grid.appendChild(cell);
            }
            
            observationPhase = 'ready';
            document.getElementById('observation-start-btn').textContent = '开始训练';
            document.getElementById('observation-desc').textContent = '找出刚才显示位置的方块，共5题';
        }
        
        function startObservation() {
            const btn = document.getElementById('observation-start-btn');
            
            if (btn.textContent === '开始训练') {
                observationRound = 0;
                btn.textContent = '记住位置...';
                btn.disabled = true;
                
                showObservationTarget();
            }
        }
        
        function clickObservationCell(cell) {
            if (observationPhase !== 'click') return;
            
            const idx = parseInt(cell.dataset.idx);
            observationPhase = 'checking';
            
            if (idx === observationTarget) {
                cell.classList.add('correct');
                currentUser.score += 30;
            } else {
                cell.classList.add('wrong');
                document.querySelectorAll('#page-game-observation .observation-cell')[observationTarget].classList.add('correct');
            }
            
            document.getElementById('observation-score').textContent = currentUser.score.toLocaleString();
            document.getElementById('stat-score').textContent = currentUser.score.toLocaleString();
            currentUser.todayTraining++;
            document.getElementById('stat-today').textContent = currentUser.todayTraining;
            observationRound++;
            
            setTimeout(() => {
                if (observationRound >= observationDifficulty + 2) {
                    document.getElementById('observation-desc').textContent = `完成! 共${observationDifficulty + 2}题`;
                    document.getElementById('observation-start-btn').textContent = '再来一次';
                    document.getElementById('observation-start-btn').disabled = false;
                } else {
                    showObservationTarget();
                }
            }, 1000);
        }
        
        function showObservationTarget() {
            const cells = document.querySelectorAll('#page-game-observation .observation-cell');
            const cellCount = observationDifficulty + 2;
            const target = Math.floor(Math.random() * (cellCount * cellCount));
            observationTarget = target;
            
            cells.forEach(c => c.className = 'observation-cell');
            cells[target].classList.add('selected');
            
            const displayTime = Math.max(800, 1500 - (observationDifficulty - 1) * 150);
            
            setTimeout(() => {
                cells[target].classList.remove('selected');
                observationPhase = 'click';
                document.getElementById('observation-start-btn').textContent = '请选择目标';
                document.getElementById('observation-start-btn').disabled = false;
            }, displayTime);
        }
        
        // ==================== 雷达图绘制 ====================
        function drawRadarChart() {
            const canvas = document.getElementById('radarCanvas');
            if (!canvas) return;
            
            const ctx = canvas.getContext('2d');
            const centerX = 100;
            const centerY = 100;
            const radius = 70;
            
            ctx.clearRect(0, 0, 200, 200);
            
            const labels = ['注意力', '记忆力', '反应力', '观察力', '逻辑思维', '创造力'];
            const values = [78, 65, 82, 71, 75, 68];
            
            ctx.strokeStyle = '#E0E0E0';
            ctx.lineWidth = 1;
            for (let i = 1; i <= 5; i++) {
                ctx.beginPath();
                for (let j = 0; j <= 6; j++) {
                    const angle = (j * 60 - 90) * Math.PI / 180;
                    const r = radius * i / 5;
                    const x = centerX + r * Math.cos(angle);
                    const y = centerY + r * Math.sin(angle);
                    if (j === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                }
                ctx.closePath();
                ctx.stroke();
            }
            
            ctx.beginPath();
            ctx.fillStyle = 'rgba(74, 144, 217, 0.3)';
            ctx.strokeStyle = 'var(--primary-blue)';
            ctx.lineWidth = 2;
            
            for (let i = 0; i <= 6; i++) {
                const angle = (i * 60 - 90) * Math.PI / 180;
                const value = i < 6 ? values[i] / 100 : values[0] / 100;
                const r = radius * value;
                const x = centerX + r * Math.cos(angle);
                const y = centerY + r * Math.sin(angle);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.closePath();
            ctx.fill();
            ctx.stroke();
            
            ctx.fillStyle = 'var(--text-dark)';
            ctx.font = '11px sans-serif';
            ctx.textAlign = 'center';
            
            for (let i = 0; i < 6; i++) {
                const angle = (i * 60 - 90) * Math.PI / 180;
                const x = centerX + (radius + 18) * Math.cos(angle);
                const y = centerY + (radius + 18) * Math.sin(angle);
                ctx.fillText(labels[i], x, y + 4);
            }
        }
        
        // ==================== 文字上传弹窗函数 ====================
        let currentTextSubject = 'math';
        
        function openTextUpload() {
            document.getElementById('text-modal').style.display = 'flex';
            document.getElementById('text-content').value = '';
            document.getElementById('text-question').value = '';
            document.getElementById('text-ai-area').style.display = 'none';
            document.getElementById('text-ai-content').innerHTML = '';
            currentTextSubject = 'math';
            updateSubjectButtons('text-subject-selector', 'math');
        }
        
        function closeTextModal() {
            document.getElementById('text-modal').style.display = 'none';
        }
        
        function selectTextSubject(subject, btn) {
            currentTextSubject = subject;
            updateSubjectButtons('text-subject-selector', subject);
        }
        
        function updateSubjectButtons(containerId, activeSubject) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const buttons = container.querySelectorAll('.subject-btn');
            buttons.forEach(btn => {
                const btnSubject = btn.getAttribute('onclick').match(/'(\w+)'/)[1];
                btn.classList.toggle('active', btnSubject === activeSubject);
            });
        }
        
        async function analyzeText() {
            const content = document.getElementById('text-content').value.trim();
            if (!content) {
                alert('请输入题目或问题内容');
                return;
            }
            
            const question = document.getElementById('text-question').value.trim();
            const aiArea = document.getElementById('text-ai-area');
            const aiContent = document.getElementById('text-ai-content');
            
            aiArea.style.display = 'block';
            aiContent.innerHTML = `
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>AI分析中...</span>
                </div>
            `;
            
            const subjectNames = { math: '数学', english: '英语', chinese: '语文' };
            const prompt = `用户正在学习${subjectNames[currentTextSubject]}，遇到了以下问题：

题目/问题：${content}
${question ? '用户描述：' + question : ''}

请提供：
1. 知识点分析
2. 解题思路
3. 相似题型推荐
4. 学习建议

请用简洁清晰的方式回复，适合中小学生理解。`;
            
            try {
                const response = await callDeepSeek(prompt);
                aiContent.innerHTML = `<div style="line-height: 1.8; white-space: pre-wrap;">${response}</div>`;
            } catch (error) {
                aiContent.innerHTML = `<div style="color: var(--error-red);">分析失败，请重试</div>`;
            }
        }
        
        // ==================== AI出题结果弹窗函数 ====================
        let currentAIQuestions = [];
        let currentAIQuestionType = '';
        let selectedAnswer = null;
        
        function openAIResultModal(title) {
            document.getElementById('ai-result-modal').style.display = 'flex';
            document.getElementById('ai-result-title').textContent = title || '🤖 AI出题';
            document.getElementById('ai-result-container').innerHTML = `
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>AI正在出题...</span>
                </div>
            `;
            document.getElementById('ai-result-actions').style.display = 'none';
        }
        
        function closeAIResultModal() {
            document.getElementById('ai-result-modal').style.display = 'none';
        }
        
        async function generateAIQuestion(type, content) {
            currentAIQuestionType = type;
            openAIResultModal('🤖 AI个性化出题');
            
            const prompts = {
                'podcast': `基于以下播客内容，生成3道理解题：
${content}
要求：选择题，包含题目、选项和正确答案。`,
                'method': `基于以下学习方法内容，生成3道应用题：
${content}
要求：选择题，包含题目、选项和正确答案。`,
                'thinking': `基于以下思维训练内容，生成3道思维题：
${content}
要求：选择题，包含题目、选项和正确答案。`,
                'topic': `基于以下母题内容，生成5道练习题：
${content}
要求：选择题，包含题目、选项和正确答案。`
            };
            
            const prompt = prompts[type] || prompts['topic'];
            
            try {
                const response = await callDeepSeek(prompt);
                const questions = parseAIQuestions(response);
                currentAIQuestions = questions;
                renderAIQuestions(questions);
            } catch (error) {
                document.getElementById('ai-result-container').innerHTML = `
                    <div style="text-align: center; padding: 40px;">
                        <div style="font-size: 48px; margin-bottom: 16px;">😔</div>
                        <div style="color: var(--error-red);">出题失败，请重试</div>
                        <button class="start-btn" style="margin-top: 16px;" onclick="regenerateQuestion()">重新出题</button>
                    </div>
                `;
            }
        }
        
        function parseAIQuestions(text) {
            // 简单解析AI返回的题目文本
            const questions = [];
            const blocks = text.split(/\d+[.、]/).filter(s => s.trim());
            let idx = 0;
            for (const block of blocks) {
                if (block.trim().length > 20) {
                    const lines = block.split('\n').filter(l => l.trim());
                    if (lines.length >= 5) {
                        const question = {
                            title: `题目 ${idx + 1}`,
                            content: lines[0]?.replace(/^[A-D][.、：:]\s*/, '') || lines[0] || '请根据内容作答',
                            options: lines.slice(1, 5).map((l, i) => ({
                                letter: String.fromCharCode(65 + i),
                                text: l.replace(/^[A-D][.、：:]\s*/, '')
                            })),
                            answer: 'A'
                        };
                        questions.push(question);
                        idx++;
                        if (idx >= 3) break;
                    }
                }
            }
            
            // 如果解析失败，生成默认题目
            if (questions.length === 0) {
                questions.push({
                    title: '理解题 1',
                    content: '请根据上述内容回答：主要知识点是什么？',
                    options: [
                        { letter: 'A', text: '知识点A' },
                        { letter: 'B', text: '知识点B' },
                        { letter: 'C', text: '知识点C' },
                        { letter: 'D', text: '知识点D' }
                    ],
                    answer: 'A'
                });
            }
            
            return questions;
        }
        
        function renderAIQuestions(questions) {
            const container = document.getElementById('ai-result-container');
            let html = '';
            
            questions.forEach((q, qIdx) => {
                html += `
                    <div class="ai-question-item">
                        <div class="ai-question-title">${q.title}</div>
                        <div class="ai-question-content">${q.content}</div>
                        <div class="ai-question-options">
                            ${q.options.map(opt => `
                                <div class="ai-question-option" onclick="selectAIAnswer(${qIdx}, '${opt.letter}')">
                                    <span class="option-letter">${opt.letter}</span>
                                    <span>${opt.text}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
            document.getElementById('ai-result-actions').style.display = 'flex';
        }
        
        function selectAIAnswer(qIdx, letter) {
            selectedAnswer = { question: qIdx, answer: letter };
            
            const options = document.querySelectorAll(`#ai-result-container .ai-question-item:nth-child(${qIdx + 1}) .ai-question-option`);
            options.forEach(opt => {
                opt.classList.remove('selected');
                if (opt.querySelector('.option-letter').textContent === letter) {
                    opt.classList.add('selected');
                }
            });
        }
        
        function regenerateQuestion() {
            generateAIQuestion(currentAIQuestionType, '');
        }
        
        function submitQuestionAnswer() {
            if (selectedAnswer) {
                alert(`答案已提交！正确答案是：${currentAIQuestions[selectedAnswer.question]?.answer}`);
                currentUser.score += 20;
                currentUser.todayTraining++;
                updateUserStats();
            } else {
                alert('请先选择答案');
            }
        }
        
        // ==================== 难度调整函数 ====================
        let currentDifficulty = 3;
        const difficultyNames = ['简单', '中等', '困难', '专家', '大师'];
        const difficultyDescriptions = [
            '简单难度：适合初学者，降低挑战，建立自信',
            '中等难度：适合大多数学习者，平衡挑战与成就感',
            '困难难度：适合有一定基础的学习者，提升能力',
            '专家难度：适合进阶学习者，全面提升思维',
            '大师难度：适合高手挑战，激发最大潜能'
        ];
        
        // 难度参数配置
        const difficultyParams = {
            schulte: ['3×3', '4×4', '5×5', '6×6', '7×7'],
            memory: ['4位', '6位', '8位', '10位', '12位'],
            reaction: ['0.8秒', '0.5秒', '0.35秒', '0.25秒', '0.15秒'],
            observation: ['简单', '中等', '困难', '专家', '大师']
        };
        
        function openDifficultyModal() {
            document.getElementById('difficulty-modal').style.display = 'flex';
            currentDifficulty = parseInt(localStorage.getItem('cognitive_training_difficulty')) || 3;
            document.getElementById('difficulty-slider').value = currentDifficulty;
            updateDifficultyPreview();
        }
        
        function closeDifficultyModal() {
            document.getElementById('difficulty-modal').style.display = 'none';
        }
        
        function updateDifficultyPreview() {
            const level = parseInt(document.getElementById('difficulty-slider').value);
            const progress = ((level - 1) / 4) * 100;
            
            document.getElementById('difficulty-progress').style.width = progress + '%';
            document.getElementById('current-difficulty-display').textContent = difficultyNames[level - 1];
            document.getElementById('difficulty-description').textContent = difficultyDescriptions[level - 1];
            
            // 更新影响范围显示
            document.getElementById('diff-schulte').textContent = difficultyParams.schulte[level - 1];
            document.getElementById('diff-memory').textContent = difficultyParams.memory[level - 1];
            document.getElementById('diff-reaction').textContent = difficultyParams.reaction[level - 1];
            document.getElementById('diff-observation').textContent = difficultyParams.observation[level - 1];
        }
        
        function saveDifficulty() {
            const level = parseInt(document.getElementById('difficulty-slider').value);
            localStorage.setItem('cognitive_training_difficulty', level);
            currentDifficulty = level;
            
            // 应用难度设置到游戏
            applyDifficultyToGames();
            
            closeDifficultyModal();
            alert(`难度已设置为：${difficultyNames[level - 1]}`);
        }
        
        function getDifficulty() {
            return parseInt(localStorage.getItem('cognitive_training_difficulty')) || 3;
        }
        
        function applyDifficultyToGames() {
            // 这些函数需要在各自的训练模块中定义
            if (typeof applySchulteDifficulty === 'function') applySchulteDifficulty();
            if (typeof applyMemoryDifficulty === 'function') applyMemoryDifficulty();
            if (typeof applyReactionDifficulty === 'function') applyReactionDifficulty();
            if (typeof applyObservationDifficulty === 'function') applyObservationDifficulty();
        }
        
        // ==================== 初始化 ====================
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('stat-days').textContent = currentUser.trainingDays;
            document.getElementById('stat-today').textContent = currentUser.todayTraining;
            document.getElementById('stat-accuracy').textContent = currentUser.accuracy + '%';
            document.getElementById('stat-score').textContent = currentUser.score.toLocaleString();
            
            // 初始化难度显示
            const savedDifficulty = parseInt(localStorage.getItem('cognitive_training_difficulty')) || 3;
            document.getElementById('difficulty-display').textContent = difficultyNames[savedDifficulty - 1];
            
            // 绑定回车发送
            document.getElementById('ai-input').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    sendAiMessage();
                }
            });
            
            // 绑定搜索回车
            document.getElementById('topic-search').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    filterTopics();
                }
            });
        });
        
        // PWA 注册
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('service-worker.js')
                .then(reg => console.log('SW registered'))
                .catch(err => console.log('SW registration failed'));
        }
    </script>
    
    <!-- ==================== 母题详情弹窗 ==================== -->
    <div class="modal-overlay" id="topic-modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title" id="modal-title">母题详情</span>
                <span class="modal-close" onclick="closeTopicModal()">✕</span>
            </div>
            
            <div class="modal-tabs">
                <div class="modal-tab active" onclick="selectModalTab(this, 'method1')">学霸方法</div>
                <div class="modal-tab" onclick="selectModalTab(this, 'method2')">思维方法</div>
                <div class="modal-tab" onclick="selectModalTab(this, 'method3')">逆向思维</div>
            </div>
            
            <div class="modal-content-area" id="modal-content-area">
                <!-- 动态内容 -->
            </div>
            
            <!-- AI分析区域 -->
            <div class="ai-analysis-area" id="modal-ai-area" style="display: none;">
                <div class="ai-analysis-header">
                    <span>🤖</span>
                    <span>AI智能分析</span>
                </div>
                <div class="ai-analysis-content" id="modal-ai-content">
                    <div class="ai-loading">
                        <span class="ai-loading-dot">●</span>
                        <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                        <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                        <span>AI分析中...</span>
                    </div>
                </div>
                <button class="start-btn" style="margin-top: 12px; background: white; color: var(--primary-blue);" onclick="callDeepSeekAnalysis()">
                    🔮 启动DeepSeek分析
                </button>
            </div>
        </div>
    </div>
    
    <!-- ==================== 拍照上传弹窗 ==================== -->
    <div class="modal-overlay" id="photo-modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title">📷 AI拍照分析</span>
                <span class="modal-close" onclick="closePhotoModal()">✕</span>
            </div>
            
            <div class="upload-form">
                <div class="photo-upload-area" id="photo-upload-area" onclick="document.getElementById('photo-file').click()">
                    <div class="photo-upload-icon">📸</div>
                    <div class="photo-upload-text">点击拍照或选择图片</div>
                    <div style="font-size: 12px; color: var(--text-gray);">支持 JPG、PNG 格式</div>
                    <input type="file" id="photo-file" accept="image/*" capture="environment" style="display: none;" onchange="handlePhotoSelect(this)">
                </div>
                <img id="photo-preview" class="photo-preview" style="display: none;">
                
                <div class="form-group">
                    <label class="form-label">描述问题（可选）</label>
                    <textarea class="form-input" id="photo-question" rows="2" placeholder="描述你遇到的问题，例如：这题不会做"></textarea>
                </div>
                
                <!-- AI分析结果 -->
                <div class="ai-analysis-area" id="photo-ai-area" style="display: none;">
                    <div class="ai-analysis-header">
                        <span>🤖</span>
                        <span>AI分析结果</span>
                    </div>
                    <div class="ai-analysis-content" id="photo-ai-content"></div>
                </div>
                
                <div style="display: flex; gap: 10px;">
                    <button class="start-btn" style="flex: 1; background: var(--bg-main); color: var(--text-dark);" onclick="closePhotoModal()">关闭</button>
                    <button class="start-btn btn-primary" style="flex: 1;" onclick="analyzePhoto()">🔮 AI分析</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ==================== 文字上传弹窗 ==================== -->
    <div class="modal-overlay" id="text-modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title">📝 AI文字分析</span>
                <span class="modal-close" onclick="closeTextModal()">✕</span>
            </div>
            
            <div class="upload-form">
                <div class="form-group">
                    <label class="form-label">学科选择</label>
                    <div class="subject-selector" id="text-subject-selector">
                        <div class="subject-btn active" onclick="selectTextSubject('math', this)">数学</div>
                        <div class="subject-btn" onclick="selectTextSubject('english', this)">英语</div>
                        <div class="subject-btn" onclick="selectTextSubject('chinese', this)">语文</div>
                    </div>
                </div>
                
                <div class="form-group">
                    <label class="form-label">输入题目或问题</label>
                    <textarea class="form-input" id="text-content" rows="6" placeholder="请输入题目内容、题干、关键词等..."></textarea>
                </div>
                
                <div class="form-group">
                    <label class="form-label">补充说明（可选）</label>
                    <textarea class="form-input" id="text-question" rows="2" placeholder="描述你遇到的问题或想了解的内容"></textarea>
                </div>
                
                <!-- AI分析结果 -->
                <div class="ai-analysis-area" id="text-ai-area" style="display: none;">
                    <div class="ai-analysis-header">
                        <span>🤖</span>
                        <span>AI分析结果</span>
                    </div>
                    <div class="ai-analysis-content" id="text-ai-content"></div>
                </div>
                
                <div style="display: flex; gap: 10px;">
                    <button class="start-btn" style="flex: 1; background: var(--bg-main); color: var(--text-dark);" onclick="closeTextModal()">关闭</button>
                    <button class="start-btn btn-primary" style="flex: 1;" onclick="analyzeText()">🔮 AI分析</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- ==================== AI出题结果弹窗 ==================== -->
    <div class="modal-overlay" id="ai-result-modal">
        <div class="modal-content" style="max-width: 90%; max-height: 85vh; overflow-y: auto;">
            <div class="modal-header">
                <span class="modal-title" id="ai-result-title">🤖 AI出题</span>
                <span class="modal-close" onclick="closeAIResultModal()">✕</span>
            </div>
            
            <div class="ai-result-container" id="ai-result-container">
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>AI正在出题...</span>
                </div>
            </div>
            
            <div class="ai-result-actions" id="ai-result-actions" style="display: none; padding: 16px; border-top: 1px solid var(--border-color);">
                <button class="start-btn" onclick="regenerateQuestion()">🔄 重新出题</button>
                <button class="start-btn" style="margin-left: 10px; background: var(--success-green);" onclick="submitQuestionAnswer()">✓ 提交答案</button>
                <button class="start-btn" style="flex: 1; margin-left: 10px; background: var(--bg-main); color: var(--text-dark);" onclick="closeAIResultModal()">关闭</button>
            </div>
        </div>
    </div>
    
    <!-- ==================== 难度调整弹窗 ==================== -->
    <div class="modal-overlay" id="difficulty-modal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title">⚙️ 难度设置</span>
                <span class="modal-close" onclick="closeDifficultyModal()">✕</span>
            </div>
            
            <div class="difficulty-container">
                <div class="current-difficulty">
                    <span class="difficulty-label">当前难度：</span>
                    <span class="difficulty-value" id="current-difficulty-display">中等</span>
                </div>
                
                <div class="difficulty-slider-area">
                    <div class="difficulty-track">
                        <div class="difficulty-progress" id="difficulty-progress"></div>
                    </div>
                    <div class="difficulty-labels">
                        <span>简单</span>
                        <span>中等</span>
                        <span>困难</span>
                        <span>专家</span>
                        <span>大师</span>
                    </div>
                    <input type="range" class="difficulty-range" id="difficulty-slider" min="1" max="5" value="3" oninput="updateDifficultyPreview()">
                </div>
                
                <div class="difficulty-description" id="difficulty-description">
                    中等难度：适合大多数学习者，平衡挑战与成就感
                </div>
                
                <div class="difficulty-games">
                    <div class="difficulty-game-title">难度影响范围：</div>
                    <div class="difficulty-game-item">
                        <span class="game-icon">🔢</span>
                        <span>舒尔特方格：<span id="diff-schulte">4×4</span></span>
                    </div>
                    <div class="difficulty-game-item">
                        <span class="game-icon">🧠</span>
                        <span>数字记忆：<span id="diff-memory">6位数字</span></span>
                    </div>
                    <div class="difficulty-game-item">
                        <span class="game-icon">⚡</span>
                        <span>反应力训练：<span id="diff-reaction">0.5秒</span></span>
                    </div>
                    <div class="difficulty-game-item">
                        <span class="game-icon">👁️</span>
                        <span>观察力训练：<span id="diff-observation">中等难度</span></span>
                    </div>
                </div>
                
                <div style="display: flex; gap: 10px; margin-top: 16px;">
                    <button class="start-btn" style="flex: 1; background: var(--bg-main); color: var(--text-dark);" onclick="closeDifficultyModal()">取消</button>
                    <button class="start-btn btn-primary" style="flex: 1;" onclick="saveDifficulty()">保存设置</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
