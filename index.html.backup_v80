            </div>
            
            <!-- 上传按钮 -->
            <button class="start-btn btn-primary" style="margin-bottom: 16px;" onclick="toggleUploadForm('method')">
                📤 上传学习方法
            </button>
            
            <!-- 上传表单 -->
            <div id="method-upload-form" class="sub-module-card" style="display: none;">
                <div class="sub-module-title">📤 上传学习方法/笔记</div>
                <div class="upload-form">
                    <div class="form-group">
                        <label class="form-label">标题 *</label>
                        <input type="text" class="form-input" id="method-title" placeholder="输入方法/笔记标题">
                    </div>
                    <div class="form-group">
                        <label class="form-label">文字内容</label>
                        <textarea class="form-input" id="method-text" rows="4" placeholder="粘贴或输入学习方法内容..."></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">附件图片（可选）</label>
                        <div class="file-upload-area" onclick="document.getElementById('method-file').click()">
                            <div class="file-upload-icon">📷</div>
                            <div style="font-size: 14px; margin-bottom: 4px;">点击上传图片</div>
                            <div class="file-upload-hint">支持 JPG、PNG 格式</div>
                        </div>
                        <input type="file" id="method-file" accept="image/*" style="display: none;" onchange="handleFileSelect(this, 'method')">
                        <div id="method-file-selected" class="file-selected" style="display: none;">
                            <span>📎</span>
                            <span class="file-name" id="method-file-name"></span>
                            <span class="file-remove" onclick="removeFile('method')">✕</span>
                        </div>
