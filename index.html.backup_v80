    <script>
        // 当前用户信息
        let currentUser = {
            name: '邱宇菲',
            grade: 6,  // 用户年级
            score: 1142,
            trainingDays: 1,
            todayTraining: 0,
            accuracy: 0
        };
        
        // 当前选择状态
        let currentGradeType = 'primary';  // primary(小学) 或 middle(初中)
        let currentGrade = 6;  // 当前年级 1-6(小学) 或 7-9(初中)
        let currentTopicSubject = 'math';
        let selectedTopic = null;
        let currentModalTab = 'method1';
        
        // ==================== 35道母题数据库（按年级分类） ====================
        const parentTopics = {
            // 小学数学（1-6年级）
            primary: {
                math: [
                    { id: 1, grade: 1, title: '20以内加减法', badge: '基础', methods: ['凑十法', '破十法', '口诀法'], desc: '掌握20以内进退位加减运算' },
                    { id: 2, grade: 2, title: '表内乘法', badge: '基础', methods: ['乘法口诀', '意义理解', '交换律'], desc: '熟练背诵乘法口诀' },
                    { id: 3, grade: 3, title: '分数初步认识', badge: '基础', methods: ['平均分法', '图示法', '大小比较'], desc: '理解分数的意义和基本运算' },
                    { id: 4, grade: 3, title: '两位数乘一位数', badge: '基础', methods: ['拆分法', '竖式法', '口算法'], desc: '掌握两位数乘一位数的计算' },
                    { id: 5, grade: 4, title: '三位数乘两位数', badge: '进阶', methods: ['竖式计算', '估算技巧', '验算方法'], desc: '熟练多位数乘法运算' },
                    { id: 6, grade: 4, title: '商不变的规律', badge: '进阶', methods: ['规律应用', '巧算技巧', '除法规律'], desc: '理解并运用商不变规律' },
                    { id: 7, grade: 5, title: '小数加减法', badge: '基础', methods: ['小数点对齐', '位数不足补零', '验算检查'], desc: '掌握小数加减法的计算方法' },
                    { id: 8, grade: 5, title: '多边形面积', badge: '进阶', methods: ['公式法', '割补法', '数方格法'], desc: '长方形、正方形、平行四边形面积' },
                    { id: 9, grade: 5, title: '分数加减法', badge: '进阶', methods: ['通分技巧', '分母不变', '约分方法'], desc: '异分母分数加减运算' },
                    { id: 10, grade: 6, title: '比的化简与应用', badge: '进阶', methods: ['比的基本性质', '化简比', '按比分配'], desc: '理解比的意义和应用' },
                    { id: 11, grade: 6, title: '圆的周长与面积', badge: '进阶', methods: ['公式记忆', 'π的取值', '综合应用'], desc: '圆的相关计算' },
                    { id: 12, grade: 6, title: '分数乘法', badge: '基础', methods: ['分子乘分子', '分母乘分母', '约分技巧'], desc: '掌握分数乘法的计算法则' }
                ],
                english: [
                    { id: 13, grade: 3, title: '26个字母认知', badge: '基础', methods: ['字母歌', '书写规范', '大小写配对'], desc: '掌握英语字母的读写' },
                    { id: 14, grade: 4, title: '一般现在时', badge: '基础', methods: ['主谓一致', '第三人称单数', '频度副词'], desc: '描述经常性动作' },
                    { id: 15, grade: 4, title: 'there be句型', badge: '基础', methods: ['就近原则', '肯定否定疑问', '数量表达'], desc: '表示某处有某物' },
                    { id: 16, grade: 5, title: '现在进行时', badge: '进阶', methods: ['be+doing', '现在分词变化', '时间标志词'], desc: '描述正在进行的动作' },
                    { id: 17, grade: 5, title: '一般过去时', badge: '进阶', methods: ['动词过去式', '规则变化', '不规则变化'], desc: '描述过去的动作' },
