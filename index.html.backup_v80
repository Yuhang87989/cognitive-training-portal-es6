                    { id: 39, grade: 8, title: '被动语态', badge: '进阶', methods: ['be+done', '各种时态', '主动变被动'], desc: '主谓关系的变化' },
                    { id: 40, grade: 9, title: '宾语从句', badge: '挑战', methods: ['语序', '时态呼应', '引导词选择'], desc: '复合句的运用' },
                    { id: 41, grade: 9, title: '定语从句', badge: '挑战', methods: ['who/which/that', '限制性与非限制性', '关系代词'], desc: '修饰名词的从句' }
                ],
                chinese: [
                    { id: 42, grade: 7, title: '文言文实词', badge: '进阶', methods: ['课内迁移', '语境推断', '词性分析'], desc: '一词多义与古今异义' },
                    { id: 43, grade: 7, title: '记叙文阅读', badge: '基础', methods: ['六要素', '线索分析', '段落作用'], desc: '把握文章脉络与中心' },
                    { id: 44, grade: 8, title: '说明文阅读', badge: '进阶', methods: ['说明方法', '说明顺序', '语言准确性'], desc: '理解说明对象与特征' },
                    { id: 45, grade: 8, title: '议论文阅读', badge: '进阶', methods: ['论点定位', '论据分析', '论证方法'], desc: '把握论证思路' },
                    { id: 46, grade: 9, title: '古诗词鉴赏', badge: '挑战', methods: ['意象分析', '情感归纳', '手法判断'], desc: '深度理解古诗词' },
                    { id: 47, grade: 9, title: '作文立意与选材', badge: '挑战', methods: ['小切口', '深挖掘', '真实感人'], desc: '确立深刻新颖的主题' }
                ]
            }
        };
        
        // ==================== 页面切换 ====================
        function switchTab(tab) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById('page-' + tab).classList.add('active');
            window.scrollTo(0, 0);
            
            if (tab === 'progress') {
                setTimeout(drawRadarChart, 100);
            }
        }
        
        function goToTraining() {
            switchTab('training');
        }
        
        function startGame(type) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById('page-game-' + type).classList.add('active');
            window.scrollTo(0, 0);
            
            if (type === 'attention') {
                initSchulteGrid();
            } else if (type === 'memory') {
                initMemoryGrid();
            } else if (type === 'observation') {
                initObservationGrid();
            }
        }
        
        function showSubModule(module) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById('page-sub-' + module).classList.add('active');
            window.scrollTo(0, 0);
            
            if (module === 'parent-topics') {
                // 根据用户年级自动选择
                autoSelectGrade();
                renderTopicList();
            }
        }
        
        function closeSubModule() {
            switchTab('home');
        }
        
        // ==================== 年级分类功能 ====================
        function autoSelectGrade() {
            // 根据用户年级自动选择
            const userGrade = currentUser.grade;
            if (userGrade <= 6) {
                currentGradeType = 'primary';
                currentGrade = userGrade;
                updateGradeTabs('primary');
                updateInnerGradeTabs('primary', userGrade);
            } else {
                currentGradeType = 'middle';
                currentGrade = userGrade;
                updateGradeTabs('middle');
                updateInnerGradeTabs('middle', userGrade);
            }
        }
        
        function selectGrade(el, type) {
            el.parentElement.querySelectorAll('.subject-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            currentGradeType = type;
            
            // 更新内部年级标签
            updateInnerGradeTabs(type, type === 'primary' ? 1 : 7);
            renderTopicList();
        }
        
        function updateGradeTabs(type) {
            const tabs = document.querySelectorAll('#grade-tabs .subject-tab');
            tabs.forEach(tab => {
                tab.classList.remove('active');
                if ((type === 'primary' && tab.textContent.includes('小学')) || 
                    (type === 'middle' && tab.textContent.includes('初中'))) {
                    tab.classList.add('active');
                }
            });
        }
        
        function updateInnerGradeTabs(type, selectedGrade) {
            const container = document.getElementById('inner-grade-tabs');
            if (type === 'primary') {
                container.innerHTML = `
                    <div class="grade-inner-tab ${selectedGrade === 1 ? 'active' : ''}" data-grade="1" onclick="selectInnerGrade(this)">1年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 2 ? 'active' : ''}" data-grade="2" onclick="selectInnerGrade(this)">2年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 3 ? 'active' : ''}" data-grade="3" onclick="selectInnerGrade(this)">3年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 4 ? 'active' : ''}" data-grade="4" onclick="selectInnerGrade(this)">4年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 5 ? 'active' : ''}" data-grade="5" onclick="selectInnerGrade(this)">5年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 6 ? 'active' : ''}" data-grade="6" onclick="selectInnerGrade(this)">6年级</div>
                `;
            } else {
                container.innerHTML = `
                    <div class="grade-inner-tab ${selectedGrade === 7 ? 'active' : ''}" data-grade="7" onclick="selectInnerGrade(this)">7年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 8 ? 'active' : ''}" data-grade="8" onclick="selectInnerGrade(this)">8年级</div>
                    <div class="grade-inner-tab ${selectedGrade === 9 ? 'active' : ''}" data-grade="9" onclick="selectInnerGrade(this)">9年级</div>
                `;
            }
            currentGrade = selectedGrade;
        }
        
        function selectInnerGrade(el) {
            el.parentElement.querySelectorAll('.grade-inner-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            currentGrade = parseInt(el.dataset.grade);
            renderTopicList();
        }
        
        // ==================== 学科选择 ====================
        function selectSubject(el, subject) {
            el.parentElement.querySelectorAll('.subject-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
        
        function selectTopicSubject(el, subject) {
            el.parentElement.querySelectorAll('.subject-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            currentTopicSubject = subject;
            renderTopicList();
        }
        
        function filterTopics() {
            renderTopicList();
        }
        
        // ==================== 母题列表渲染 ====================
        function renderTopicList() {
            const list = document.getElementById('parent-topic-list');
            const search = document.getElementById('topic-search').value.toLowerCase();
            
            // 获取当前年级类型的母题
            const topics = parentTopics[currentGradeType][currentTopicSubject].filter(t => 
                t.grade === currentGrade && 
                (t.title.toLowerCase().includes(search) || t.desc.toLowerCase().includes(search))
            );
            
            const badgeClass = currentTopicSubject === 'math' ? 'badge-math' : 
                               currentTopicSubject === 'english' ? 'badge-english' : 'badge-chinese';
            
            const subjectIcon = currentTopicSubject === 'math' ? '📐' : 
                               currentTopicSubject === 'english' ? '📖' : '📝';
            
            if (topics.length === 0) {
                list.innerHTML = `
                    <div style="text-align: center; padding: 40px 20px; color: var(--text-gray);">
                        <div style="font-size: 48px; margin-bottom: 12px;">📭</div>
                        <div>暂无该年级相关母题</div>
                        <div style="font-size: 12px; margin-top: 8px;">试试切换年级或学科</div>
                    </div>
                `;
                return;
            }
            
            list.innerHTML = topics.map(t => `
                <div class="parent-topic-item" onclick="openTopicDetail(${t.id})">
                    <div class="parent-topic-header">
                        <div class="parent-topic-title">
                            ${subjectIcon} ${t.title}
                        </div>
                        <span class="parent-topic-badge ${badgeClass}">${t.badge}</span>
                    </div>
                    <div style="font-size: 12px; color: var(--text-gray); margin-bottom: 6px;">${t.desc}</div>
                    <div class="parent-topic-methods">
                        ${t.methods.map(m => `<span>${m}</span>`).join('')}
                    </div>
                </div>
            `).join('');
        }
        
        // ==================== 母题详情弹窗 ====================
        function openTopicDetail(id) {
            let topic = null;
            for (const gradeType in parentTopics) {
                for (const subject in parentTopics[gradeType]) {
                    const found = parentTopics[gradeType][subject].find(t => t.id === id);
                    if (found) {
                        topic = found;
                        break;
                    }
                }
                if (topic) break;
            }
            
            if (!topic) return;
            selectedTopic = topic;
            
            document.getElementById('modal-title').textContent = topic.title;
            document.getElementById('modal-content-area').innerHTML = getMethodContent('method1');
            document.getElementById('modal-ai-area').style.display = 'none';
            
            // 重置tab
            document.querySelectorAll('.modal-tab').forEach((t, i) => {
                t.classList.toggle('active', i === 0);
            });
            currentModalTab = 'method1';
            
            document.getElementById('topic-modal').classList.add('active');
        }
        
        function closeTopicModal() {
            document.getElementById('topic-modal').classList.remove('active');
        }
        
        function selectModalTab(el, tab) {
            el.parentElement.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            currentModalTab = tab;
            document.getElementById('modal-content-area').innerHTML = getMethodContent(tab);
            document.getElementById('modal-ai-area').style.display = 'block';
        }
        
        function getMethodContent(tab) {
            if (!selectedTopic) return '';
            
            const contents = {
                method1: `
                    <div class="method-section">
                        <div class="method-title">📚 学霸方法 - ${selectedTopic.title}</div>
                        <div class="method-content">
                            <p><strong>核心要点：</strong></p>
                            <p>1. 理解基本概念，建立知识框架</p>
                            <p>2. 掌握经典解法，形成解题套路</p>
                            <p>3. 多做变式练习，举一反三</p>
                            <p>4. 总结易错点，避免常见陷阱</p>
                            <br>
                            <p><strong>学习技巧：</strong></p>
                            <p>• 先看例题，理解解题思路</p>
                            <p>• 遮住答案，独立完成练习</p>
                            <p>• 完成后对照，检查思路差异</p>
                        </div>
                    </div>
                `,
                method2: `
                    <div class="method-section">
                        <div class="method-title">🧠 思维方法 - ${selectedTopic.title}</div>
                        <div class="method-content">
                            <p><strong>思维模型：</strong></p>
                            <p>1. <strong>归纳法：</strong>从特殊到一般，从具体到抽象</p>
                            <p>2. <strong>演绎法：</strong>从一般到特殊，从抽象到具体</p>
                            <p>3. <strong>类比法：</strong>寻找相似点，迁移方法</p>
                            <p>4. <strong>转化法：</strong>将复杂问题转化为简单问题</p>
                            <br>
                            <p><strong>训练步骤：</strong></p>
                            <p>• 第一步：识别问题类型</p>
                            <p>• 第二步：选择合适思维方法</p>
                            <p>• 第三步：执行解题策略</p>
                            <p>• 第四步：验证结果正确性</p>
                        </div>
                    </div>
                `,
                method3: `
                    <div class="method-section">
                        <div class="method-title">🔄 逆向思维 - ${selectedTopic.title}</div>
                        <div class="method-content">
                            <p><strong>逆向思维的核心：</strong></p>
                            <p>从问题的终点出发，反向推导解题步骤。</p>
                            <br>
                            <p><strong>适用场景：</strong></p>
                            <p>• 复杂问题找不到切入点</p>
                            <p>• 正向推导过于繁琐</p>
                            <p>• 需要验证答案正确性</p>
                            <br>
                            <p><strong>逆向步骤：</strong></p>
                            <p>1. 明确最终目标/答案形式</p>
                            <p>2. 思考"要得到这个结果需要什么"</p>
                            <p>3. 继续追问，逆向追溯</p>
                            <p>4. 正向写出完整解题过程</p>
                        </div>
                    </div>
                `
            };
            
            return contents[tab] || '';
        }
        
        // ==================== DeepSeek API 调用 ====================
        async function callDeepSeek(prompt) {
            const apiKey = localStorage.getItem('deepseek_api_key');
            if (!apiKey) {
                return { error: '请先在设置中配置DeepSeek API Key' };
            }
            
            try {
                const response = await fetch('https://api.deepseek.com/v1/chat/completions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${apiKey}`
                    },
                    body: JSON.stringify({
                        model: 'deepseek-chat',
                        messages: [{ role: 'user', content: prompt }],
                        temperature: 0.7
                    })
                });
                
                const data = await response.json();
                if (data.error) {
                    return { error: data.error.message };
                }
                return { result: data.choices[0].message.content };
            } catch (error) {
                return { error: '网络请求失败，请检查网络连接' };
            }
        }
        
        async function callDeepSeekAnalysis() {
            if (!selectedTopic) return;
            
            const content = document.getElementById('modal-ai-content');
            content.innerHTML = `
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>DeepSeek AI分析中...</span>
                </div>
            `;
            
            const prompt = `请分析以下母题 "${selectedTopic.title}" 的特点：
            1. 这类题目的核心考点是什么？
            2. 常见的解题陷阱有哪些？
            3. 如何快速准确地解答这类题目？
            4. 给出一道典型例题及详细解答步骤。
            
            请用简洁易懂的语言回答，适合中小学生理解。`;
            
            const result = await callDeepSeek(prompt);
            
            if (result.error) {
                content.innerHTML = `<div style="color: #F44336;">⚠️ ${result.error}<br><br>请在设置中添加您的DeepSeek API Key</div>`;
            } else {
                content.innerHTML = `<div style="line-height: 1.8;">${result.result.replace(/\n/g, '<br>')}</div>`;
            }
        }
        
        // ==================== 拍照上传功能 ====================
        function openPhotoUpload() {
            document.getElementById('photo-modal').classList.add('active');
        }
        
        function closePhotoModal() {
            document.getElementById('photo-modal').classList.remove('active');
            document.getElementById('photo-preview').style.display = 'none';
            document.getElementById('photo-ai-area').style.display = 'none';
        }
        
        function handlePhotoSelect(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('photo-preview').src = e.target.result;
                    document.getElementById('photo-preview').style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        async function analyzePhoto() {
            const preview = document.getElementById('photo-preview');
            const question = document.getElementById('photo-question').value;
            
            if (preview.style.display === 'none') {
                alert('请先上传题目图片');
                return;
            }
            
            const content = document.getElementById('photo-ai-content');
            content.innerHTML = `
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>AI正在分析图片...</span>
                </div>
            `;
            document.getElementById('photo-ai-area').style.display = 'block';
            
            const prompt = `请分析这张学习题目的图片：
            ${question ? `用户的问题描述：${question}` : ''}
            
            请给出：
            1. 这道题考查的知识点
            2. 解题思路和步骤
            3. 详细的解答过程
            4. 类似的练习题推荐
            
            请用简洁易懂的语言回答。`;
            
            const result = await callDeepSeek(prompt);
            
            if (result.error) {
                content.innerHTML = `<div style="color: #F44336;">⚠️ ${result.error}</div>`;
            } else {
                content.innerHTML = `<div style="line-height: 1.8;">${result.result.replace(/\n/g, '<br>')}</div>`;
            }
        }
        
        // ==================== AI出题功能 ====================
        async function generateAIQuestion() {
            const input = document.getElementById('ai-question-input').value.trim();
            if (!input) {
                alert('请输入想练习的知识点');
                return;
            }
            
            const tags = document.querySelectorAll('#page-sub-parent-topics .ai-question-tag.active');
            const difficulty = Array.from(tags).map(t => t.textContent).join('、') || '基础题';
            const gradeName = currentGradeType === 'primary' ? `小学${currentGrade}年级` : `初中${currentGrade}年级`;
            
            const content = document.getElementById('ai-generated-question');
            const questionContent = document.getElementById('ai-question-content');
            
            questionContent.innerHTML = `
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>AI正在生成题目...</span>
                </div>
            `;
            content.style.display = 'block';
            
            const prompt = `请根据以下要求生成一道适合${gradeName}学生的练习题：
            知识点：${input}
            难度：${difficulty}
            学科：${currentTopicSubject === 'math' ? '数学' : currentTopicSubject === 'english' ? '英语' : '语文'}
            
            请生成：
            1. 一道完整的练习题
            2. 详细的解题步骤
            3. 答案
            4. 知识点解析
            
            请用适合该年级学生理解的方式呈现。`;
            
            const result = await callDeepSeek(prompt);
            
            if (result.error) {
                questionContent.innerHTML = `<div style="color: #F44336;">⚠️ ${result.error}</div>`;
            } else {
                questionContent.innerHTML = `<div style="line-height: 1.8;">${result.result.replace(/\n/g, '<br>')}</div>`;
            }
        }
        
        // ==================== AI超级老师 ====================
        async function sendAiMessage() {
            const input = document.getElementById('ai-input');
            const question = input.value.trim();
            if (!question) return;
            
            const responseArea = document.getElementById('ai-response-area');
            const responseContent = document.getElementById('ai-response-content');
            
            responseArea.style.display = 'block';
            responseContent.innerHTML = `
                <div class="ai-loading">
                    <span class="ai-loading-dot">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.2s">●</span>
                    <span class="ai-loading-dot" style="animation-delay: 0.4s">●</span>
                    <span>AI正在思考...</span>
                </div>
            `;
            
            const result = await callDeepSeek(`你是AI学习助手，请回答学生的问题：${question}`);
            
            if (result.error) {
                responseContent.innerHTML = `<div style="color: #F44336;">⚠️ ${result.error}</div>`;
            } else {
                responseContent.innerHTML = result.result.replace(/\n/g, '<br>');
            }
            
            input.value = '';
        }
        
        function askQuestion(question) {
            document.getElementById('ai-input').value = question;
            sendAiMessage();
        }
        
        // ==================== 上传功能 ====================
        function toggleUploadForm(type) {
            const form = document.getElementById(type + '-upload-form');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
        
        function handleFileSelect(input, type) {
            if (input.files && input.files[0]) {
                const fileName = input.files[0].name;
                document.getElementById(type + '-file-name').textContent = fileName;
                document.getElementById(type + '-file-selected').style.display = 'flex';
            }
        }
        
        function removeFile(type) {
            document.getElementById(type + '-file').value = '';
            document.getElementById(type + '-file-selected').style.display = 'none';
        }
        
        function cancelUpload(type) {
            document.getElementById(type + '-upload-form').style.display = 'none';
            removeFile(type);
            document.getElementById(type + '-title').value = '';
            document.getElementById(type + '-desc').value = '';
        }
        
